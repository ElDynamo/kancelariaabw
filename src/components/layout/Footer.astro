---
import { client } from '../../../tina/__generated__/client';

const response = await client.queries.contact({ relativePath: 'contact.json' });
const contactData = response.data.contact;

const services = [
  { label: 'Prawo rodzinne', href: '/uslugi/prawo-rodzinne' },
  { label: 'Prawo cywilne', href: '/uslugi/prawo-cywilne' },
  { label: 'Prawo karne', href: '/uslugi/prawo-karne' },
];

const legal = contactData.footerNav || [
  { label: 'Polityka prywatności', href: '/polityka-prywatnosci' },
  { label: 'Regulamin', href: '/regulamin' },
  { label: 'Przetwarzanie danych', href: '/przetwarzanie-danych' },
];
---
<footer class="bg-navy text-white">
  <div class="container-site py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Kolumna 1: O kancelarii -->
      <div>
        <p class="font-serif text-xl mb-2">Kancelaria Prawna ABW</p>
        <p class="font-sans text-sm text-white opacity-70 mb-4">Radca Prawny Anna Jarczyńska</p>
        <p class="font-sans text-sm text-white opacity-60 leading-relaxed">
          Profesjonalna pomoc prawna we Wrocławiu. Prawo rodzinne, cywilne i karne.
        </p>
      </div>

      <!-- Kolumna 2: Usługi -->
      <div>
        <h2 class="font-sans text-xs uppercase tracking-widest text-gold mb-4">Usługi</h2>
        <ul class="space-y-2" role="list">
          {services.map(s => (
            <li>
              <a href={s.href} class="font-sans text-sm text-white opacity-70 hover:text-gold transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kolumna 3: Kontakt -->
      <div>
        <h2 class="font-sans text-xs uppercase tracking-widest text-gold mb-5">Kontakt</h2>
        <address class="not-italic space-y-4">
          <div>
            <p class="font-sans text-xs text-white opacity-40 uppercase tracking-wide mb-1">Telefon</p>
            <a href={`tel:${contactData?.phone?.replace(/\s+/g, '')}`} class="font-sans text-sm text-white opacity-80 hover:text-gold transition-colors">
              {contactData?.phone || '609 366 160'}
            </a>
          </div>
          <div>
            <p class="font-sans text-xs text-white opacity-40 uppercase tracking-wide mb-1">Email</p>
            <a href={`mailto:${contactData?.email}`} class="font-sans text-sm text-white opacity-80 hover:text-gold transition-colors break-all">
              {contactData?.email || 'a.jarczynska@kancelariaabw.pl'}
            </a>
          </div>
          <div>
            <p class="font-sans text-xs text-white opacity-40 uppercase tracking-wide mb-1">Lokalizacje</p>
            <p class="font-sans text-sm text-white opacity-80">{contactData?.locations}</p>
          </div>
          <div>
            <p class="font-sans text-xs text-white opacity-40 uppercase tracking-wide mb-1">Godziny pracy</p>
            <p class="font-sans text-sm text-white opacity-80">Pon.–Pt., 9:00–17:00</p>
          </div>
        </address>
      </div>

    </div>

    <!-- Dół footera -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-sans text-xs text-white opacity-40">
        © {new Date().getFullYear()} Kancelaria Prawna ABW. Wszelkie prawa zastrzeżone.
      </p>
      <nav aria-label="Linki prawne">
        <ul class="flex gap-6" role="list">
          {legal.map((l: any) => (
            <li>
              <a href={l.href} class="font-sans text-xs text-white opacity-40 hover:text-gold transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
