---
import { getEntry } from 'astro:content';

const contactEntry = await getEntry('singletons', 'contact');
const navLinks = contactEntry?.data?.headerNav || [
  { href: '/', label: 'Strona główna' },
  { href: '/uslugi', label: 'Usługi' },
  { href: '/cennik', label: 'Cennik' },
  { href: '/blog', label: 'Blog' },
  { href: '/narzedzia', label: 'Narzędzia' },
  { href: '/o-mnie', label: 'O mnie' },
  { href: '/kontakt', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<div id="cms-preview-banner" class="hidden bg-[#0f2540] text-gold w-full px-4 py-2 items-center justify-between z-[60] relative font-sans text-xs border-b border-gold/30">
  <div class="flex items-center gap-3">
    <span class="animate-pulse w-2 h-2 rounded-full bg-red-500"></span>
    <span class="font-bold tracking-widest uppercase">Tryb Podglądu CMS</span>
    <span class="hidden md:inline pl-3 border-l border-white/20 text-white/70">Szkice są aktualnie widoczne.</span>
  </div>
  <div class="flex items-center gap-2">
    <a href="/api/exit-preview" class="px-3 py-1 bg-white/10 hover:bg-white/20 text-white rounded transition-colors text-[10px] uppercase font-bold tracking-wider">
      Zakończ
    </a>
    <button id="cmsDeployBtn" class="px-3 py-1 bg-gold text-[#0f2540] hover:bg-gold/90 rounded transition-colors text-[10px] uppercase font-bold tracking-wider flex items-center gap-1">
      Publikuj zmiany
    </button>
  </div>
</div>

<script>
  // Sprawdzenie na żywo ciasteczka preview=true (Klient-side rendering panelu admina)
  if (document.cookie.includes('preview=true')) {
    const banner = document.getElementById('cms-preview-banner');
    if (banner) {
      banner.classList.remove('hidden');
      banner.classList.add('flex');
    }
  }

  const btn = document.getElementById('cmsDeployBtn');
  if (btn) {
    btn.addEventListener('click', async () => {
      btn.textContent = 'Trwa...';
      btn.classList.add('opacity-50', 'cursor-not-allowed');
      try {
        const res = await fetch('/api/build', { method: 'POST' });
        if (res.ok) {
          alert("Publikacja rozpoczęta! Zmiany pojawią się za około 30 sekund.");
          btn.textContent = 'Opublikowano';
        } else {
          alert("Błąd integracji z systemem budowania.");
          btn.textContent = 'Błąd';
        }
      } catch(e) {
        alert("Błąd połączenia.");
        btn.textContent = 'Publikuj zmiany';
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
    });
  }
</script>

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <div class="container-site">
    <nav class="flex items-center justify-between h-16 lg:h-20" aria-label="Nawigacja główna">

      <!-- Logo -->
      <a href="/" class="flex flex-col leading-tight" aria-label="Kancelaria Prawna ABW — strona główna">
        <span class="font-serif text-lg text-navy font-normal tracking-wide">Kancelaria Prawna ABW</span>
        <span class="font-sans text-xs text-text-muted uppercase tracking-widest">Radca Prawny Anna Jarczyńska</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden lg:flex items-center gap-8" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'font-sans text-xs uppercase tracking-widest transition-colors duration-200',
                currentPath === link.href
                  ? 'text-gold font-medium'
                  : 'text-text-muted hover:text-navy',
              ]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA Button -->
      <a
        href="/kontakt"
        class="hidden lg:inline-flex btn-primary"
        aria-label="Umów konsultację prawną"
      >
        Umów konsultację
      </a>

      <!-- Mobile menu button — Vue Island -->
      <button
        type="button"
        class="lg:hidden p-2 text-navy"
        aria-label="Otwórz menu"
        aria-expanded="false"
        id="mobile-menu-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white" role="navigation" aria-label="Menu mobilne">
    <ul class="container-site py-4 flex flex-col gap-4" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block font-sans text-sm uppercase tracking-widest py-2 transition-colors',
              currentPath === link.href ? 'text-gold' : 'text-text-muted hover:text-navy',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/kontakt" class="btn-primary inline-block w-full text-center mt-2">
          Umów konsultację
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
