---
interface Props {
  title: string;
  type?: 'warning' | 'info' | 'success';
}
const { title, type = 'info' } = Astro.props;

const config = {
  warning: { bg: 'bg-red-50', border: 'border-red-200', text: 'text-red-900', iconColor: 'text-red-500' },
  info: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-900', iconColor: 'text-blue-500' },
  success: { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-900', iconColor: 'text-green-500' }
};

const style = config[type];
---

<div class={`my-6 rounded-xl border ${style.bg} ${style.border} p-5 flex gap-4 items-start`}>
  <div class={`shrink-0 mt-0.5 ${style.iconColor}`}>
    {type === 'warning' && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>}
    {type === 'info' && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>}
    {type === 'success' && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>}
  </div>
  <div>
    <h4 class={`font-sans font-bold text-sm uppercase tracking-wide mb-1 ${style.text}`}>{title}</h4>
    <div class={`font-sans text-sm leading-relaxed opacity-90 ${style.text} prose-p:my-1`}>
      <slot />
    </div>
  </div>
</div>
