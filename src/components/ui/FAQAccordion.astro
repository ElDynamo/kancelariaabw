---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
  class?: string;
}

const { items, title, class: extraClass = '' } = Astro.props;
---

{items && items.length > 0 && (
  <section class:list={['section bg-off-white', extraClass]}>
    <div class="container-site max-w-3xl">
      {title && (
        <div class="mb-8">
          <div class="flex items-center gap-2 mb-3">
            <span class="h-px w-8 bg-gold"></span>
            <span class="font-sans text-xs uppercase tracking-widest text-gold">FAQ</span>
          </div>
          <h2 class="font-serif text-3xl text-navy">{title}</h2>
        </div>
      )}
      <div class="space-y-4">
        {items.map(f => (
          <details class="bg-white rounded-xl border border-border p-5 group">
            <summary class="font-sans font-semibold text-navy cursor-pointer list-none flex justify-between items-center">
              {f.question}
              <span class="text-gold text-lg ml-4">+</span>
            </summary>
            <p class="font-sans text-text-muted text-sm mt-3 leading-relaxed">{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
