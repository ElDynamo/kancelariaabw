---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  variant?: 'light' | 'dark';
}

const { items, variant = 'light' } = Astro.props;

const textClass = variant === 'dark'
  ? 'text-white opacity-50'
  : 'text-text-muted';
const hoverClass = variant === 'dark'
  ? 'hover:text-white'
  : 'hover:text-navy';
const currentClass = variant === 'dark'
  ? 'text-white opacity-80'
  : 'text-navy';
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class:list={['flex items-center gap-2 font-sans text-sm flex-wrap', textClass]}>
    {items.map((item, idx) => (
      <>
        {idx > 0 && <li aria-hidden="true">›</li>}
        <li>
          {idx < items.length - 1 && item.href ? (
            <a href={item.href} class={hoverClass}>{item.label}</a>
          ) : (
            <span aria-current="page" class={currentClass}>{item.label}</span>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
