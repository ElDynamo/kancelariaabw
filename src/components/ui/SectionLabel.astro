---
interface Props {
  text: string;
  class?: string;
}

const { text, class: extraClass = '' } = Astro.props;
---

<div class:list={['flex items-center gap-2', extraClass]}>
  <span class="h-px w-8 bg-gold"></span>
  <span class="font-sans text-xs uppercase tracking-widest text-gold">{text}</span>
</div>
