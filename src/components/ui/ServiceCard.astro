---
interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href } = Astro.props;
---
<article class="island-card group relative hover:border-gold/50 hover:bg-off-white/50 transition-colors duration-500 flex flex-col w-full h-full">
  <!-- Minimalist icon slot -->
  <div class="w-10 h-10 text-navy/80 group-hover:text-gold transition-colors duration-500">
    <slot name="icon" />
  </div>
  
  <div class="flex-grow flex flex-col gap-3">
    <h3 class="font-serif text-2xl text-navy group-hover:text-gold transition-colors duration-500">{title}</h3>
    <p class="font-sans text-base text-text-muted leading-relaxed">{description}</p>
  </div>
  
  {href && (
    <div class="mt-auto pt-4">
      <a
        href={href}
        class="inline-flex items-center gap-3 font-sans text-xs text-navy uppercase tracking-[0.2em] group-hover:text-gold transition-colors duration-500 overflow-hidden"
        aria-label={`Dowiedz się więcej o: ${title}`}
      >
        <span>Odkryj</span>
        <span class="w-8 h-px bg-current transform origin-left transition-transform duration-500 scale-x-50 group-hover:scale-x-100"></span>
      </a>
      <!-- Entire card clickable overlay -->
      <a href={href} class="absolute inset-0 z-10" aria-hidden="true"><span class="sr-only">{title}</span></a>
    </div>
  )}
</article>
