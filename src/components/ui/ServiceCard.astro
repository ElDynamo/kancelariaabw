---
interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href } = Astro.props;
---
<article class="group border border-border rounded-2xl p-6 lg:p-8 hover:border-gold hover:shadow-lg transition-all duration-300 flex flex-col gap-4">
  <!-- Ikona przekazana przez slot -->
  <div class="w-12 h-12 rounded-xl bg-navy/5 flex items-center justify-center">
    <slot name="icon" />
  </div>
  <div class="flex flex-col gap-2">
    <h3 class="font-serif text-xl text-navy group-hover:text-gold transition-colors">{title}</h3>
    <p class="font-sans text-sm text-text-muted leading-relaxed">{description}</p>
  </div>
  {href && (
    <a
      href={href}
      class="mt-auto font-sans text-sm text-navy uppercase tracking-wider hover:text-gold transition-colors flex items-center gap-1"
      aria-label={`Dowiedz się więcej o: ${title}`}
    >
      Dowiedz się więcej →
    </a>
  )}
</article>
