---
// Komponent do użycia na stronach blogowych — pokazuje autora z linkiem do /o-mnie
interface Props {
  author?: string;
  publishDate?: Date | string;
  lastModified?: Date | string;
  readingTime?: number;
}
const {
  author = "Anna Jarczyńska",
  publishDate,
  lastModified,
  readingTime,
} = Astro.props;

function formatDate(d: Date | string | undefined) {
  if (!d) return null;
  return new Date(d).toLocaleDateString("pl-PL", { day: "numeric", month: "long", year: "numeric" });
}
---

<div class="not-prose flex items-center gap-4 py-4 border-y border-border my-6">
  <a href="/o-mnie" class="shrink-0">
    <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold font-serif text-lg font-bold">
      AJ
    </div>
  </a>
  <div class="flex-1">
    <p class="font-sans text-sm font-semibold text-navy">
      <a href="/o-mnie" class="hover:text-gold transition-colors">{author}</a>
      <span class="font-normal text-text-muted ml-1">— Radca Prawny, nr wpisu OIRP WR-3019</span>
    </p>
    <div class="flex flex-wrap gap-x-4 gap-y-1 mt-1 font-sans text-xs text-text-muted">
      {publishDate && <span>Opublikowano: {formatDate(publishDate)}</span>}
      {lastModified && publishDate !== lastModified && <span>Aktualizacja: {formatDate(lastModified)}</span>}
      {readingTime && <span>Czas czytania: ok. {readingTime} min</span>}
    </div>
  </div>
  <a href="/o-mnie" class="hidden sm:block font-sans text-xs text-navy/60 hover:text-navy transition-colors border border-border rounded-lg px-3 py-2 whitespace-nowrap">
    Profil radcy →
  </a>
</div>
