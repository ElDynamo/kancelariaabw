---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import SectionLabel from '@components/ui/SectionLabel.astro';
import ToolCTA from '@components/ui/ToolCTA.astro';
import CourtFeesCalculator from '@components/tools/CourtFeesCalculator.vue';

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
    { "@type": "ListItem", "position": 3, "name": "Opłaty sądowe", "item": "https://kancelariaabw.pl/narzedzia/oplaty-sadowe" },
  ]
};
const webAppSchema = {
  "@context": "https://schema.org", "@type": "WebApplication",
  "name": "Kalkulator Opłat Sądowych 2025",
  "url": "https://kancelariaabw.pl/narzedzia/oplaty-sadowe",
  "applicationCategory": "LegalService",
  "description": "Bezpłatny kalkulator opłat sądowych. Sprawdź ile kosztuje pozew — rozwód, alimenty, podział majątku, zachowek. Aktualne stawki UKSC 2025.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" },
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW" }
};
---
<Layout
  title="Kalkulator Opłat Sądowych 2025 — ile kosztuje pozew?"
  description="Kalkulator opłat sądowych w sprawach cywilnych. Sprawdź koszt pozwu: rozwód 600 zł, alimenty 0 zł, podział majątku 300–1000 zł. Aktualne stawki UKSC 2025."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
    <StructuredData schema={webAppSchema} />
  </Fragment>
  <section class="section bg-white">
    <div class="w-full max-w-7xl mx-auto px-6 lg:px-8 max-w-5xl">
      <Breadcrumb items={[
        { label: 'Strona główna', href: '/' },
        { label: 'Narzędzia prawne', href: '/narzedzia' },
        { label: 'Opłaty sądowe' },
      ]} />
      <SectionLabel text="Narzędzia prawne" class="mb-4 reveal" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-10">
        <div class="reveal delay-100">
          <h1 class="heading-xl mb-4">Kalkulator opłat sądowych<br /><span class="text-gold">2025</span></h1>
          <p class="text-body text-lg max-w-2xl">
            Ile kosztuje pozew? Sprawdź opłatę sądową dla swojej sprawy — rozwód, alimenty, podział majątku,
            zachowek i inne roszczenia cywilne. Uwzględnia nowelizację UKSC z 23 IX 2025 r.
          </p>
        </div>
        <div class="reveal delay-200 flex justify-center md:justify-end">
             <img src="/tools/court_fees_graphic_pl_1772990300994.png" alt="Grafika wektorowa opłaty sądowe" class="rounded-[2.5rem] shadow-2xl shadow-navy/10 transform rotate-1 hover:rotate-0 transition-transform duration-500 w-full max-w-sm lg:max-w-md object-contain p-2 bg-white">
        </div>
      </div>

      <!-- Calculator -->
      <div class="md:bg-off-white md:rounded-3xl md:p-10 mb-12 md:border md:border-border w-full md:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.05)]">
        <CourtFeesCalculator client:visible />
      </div>
      <article class="prose prose-navy max-w-3xl mx-auto reveal">
        <h2>Opłaty sądowe w sprawach cywilnych — co warto wiedzieć</h2>
        <p>
          Opłaty sądowe reguluje <strong>ustawa z 28 lipca 2005 r. o kosztach sądowych
          w sprawach cywilnych (UKSC)</strong>. System dzieli się na opłaty stałe (określona kwota)
          i stosunkowe (procent od wartości przedmiotu sporu).
        </p>
        <h3>Nowelizacja UKSC — 23 IX 2025</h3>
        <p>
          Od 23 września 2025 r. maksymalna opłata stosunkowa wynosi <strong>100 000 zł</strong>
          (wcześniej 200 000 zł). Zmiana dotyczy m.in. postępowań o wysokim WPS.
        </p>
        <h3>Zwolnienie z opłat sądowych</h3>
        <p>
          Strona może ubiegać się o zwolnienie z kosztów sądowych, jeśli wykaże, że bez uszczerbku
          dla utrzymania koniecznego własnego i rodziny nie jest w stanie ponieść kosztów (art. 102 UKSC).
          Wniosek składa się razem z pismem procesowym lub odrębnie.
        </p>
      </article>

      <ToolCTA
        title="Masz pytania o koszty sprawy?"
        description="Skonsultuj swoją sytuację — ocenimy czy masz szansę na zwolnienie z kosztów i jak zaplanować budżet sprawy."
        secondaryText="Zobacz cennik kancelarii"
        secondaryHref="/cennik"
      />
    </div>
  </section>
</Layout>
