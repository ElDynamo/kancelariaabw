---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import DivorceCalculator from '@components/tools/DivorceCalculator.vue';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
    { "@type": "ListItem", "position": 3, "name": "Kalkulator kosztów rozwodu", "item": "https://kancelariaabw.pl/narzedzia/koszty-rozwodu" },
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Kalkulator Kosztów Rozwodu 2025",
  "url": "https://kancelariaabw.pl/narzedzia/koszty-rozwodu",
  "applicationCategory": "LegalService",
  "operatingSystem": "Web",
  "description": "Bezpłatny kalkulator kosztów rozwodu. Oblicz opłatę sądową, honorarium prawnika i inne koszty postępowania rozwodowego w Polsce.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" },
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ile kosztuje pozew o rozwód?",
      "acceptedAnswer": { "@type": "Answer", "text": "Opłata sądowa od pozwu o rozwód wynosi 600 zł (art. 26 ust. 1 pkt 1 UKSC). Przy orzeczeniu bez winy sąd zwraca 300 zł (art. 79 UKSC). Do tego dochodzą koszty prawnika — od 3 000 zł za sprawę prostą." }
    },
    {
      "@type": "Question",
      "name": "Czy można odzyskać opłatę sądową za rozwód?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tak — przy wyroku orzekającym rozwód bez orzekania o winie sąd zwraca połowę opłaty sądowej, czyli 300 zł (art. 79 ust. 1 pkt 1 UKSC). Zwrot następuje automatycznie po uprawomocnieniu." }
    },
    {
      "@type": "Question",
      "name": "Ile trwa sprawa o rozwód?",
      "acceptedAnswer": { "@type": "Answer", "text": "Przy rozwodzie bez orzekania o winie i bez dzieci — 2 do 4 miesięcy. Ze sporem o opiekę nad dziećmi — 8 do 24 miesięcy." }
    },
    {
      "@type": "Question",
      "name": "Czy mediacja obniża koszty rozwodu?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tak. Mediacja może skrócić postępowanie i obniżyć koszty. Przy ugodzie w toku mediacji sąd może zwrócić 3/4 opłaty sądowej (art. 79 ust. 1 pkt 2 UKSC)." }
    },
    {
      "@type": "Question",
      "name": "Jak uniknąć orzekania o winie?",
      "acceptedAnswer": { "@type": "Answer", "text": "Obie strony muszą złożyć zgodny wniosek o divorce bez orzekania o winie. Sąd wówczas pomija badanie winy. To szybsza i tańsza ścieżka." }
    }
  ]
};
---

<Layout
  title="Kalkulator Kosztów Rozwodu 2025 — ile kosztuje rozwód?"
  description="Bezpłatny kalkulator kosztów rozwodu w Polsce. Opłata sądowa 600 zł + honorarium prawnika + podział majątku. Sprawdź szacunkowe koszty i czas postępowania."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
    <StructuredData schema={webAppSchema} />
    <StructuredData schema={faqSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="container-site max-w-5xl">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-sans text-sm text-text-muted">
          <li><a href="/" class="hover:text-navy">Strona główna</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/narzedzia" class="hover:text-navy">Narzędzia prawne</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-navy">Kalkulator kosztów rozwodu</li>
        </ol>
      </nav>

      <!-- Header -->
      <div class="flex items-center gap-2 mb-4 reveal">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Narzędzia prawne</span>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-10">
        <div class="reveal delay-100">
          <h1 class="heading-xl mb-4">
            Kalkulator kosztów rozwodu<br />
            <span class="text-gold">2025</span>
          </h1>
          <p class="text-body text-lg max-w-2xl">
            Ile kosztuje rozwód w Polsce? Oblicz szacunkowy koszt postępowania — opłatę sądową,
            honorarium radcy prawnego i dodatkowe wydatki. Wyniki opierają się na aktualnych
            przepisach UKSC i stawkach rynkowych (Wrocław 2025).
          </p>
        </div>
        <div class="reveal delay-200 flex justify-center md:justify-end">
             <img src="/tools/divorce_cost_graphic_pl_1772990272156.png" alt="Grafika wektorowa kalkulator rozwodowy" class="rounded-[2.5rem] shadow-2xl shadow-navy/10 transform rotate-1 hover:rotate-0 transition-transform duration-500 w-full max-w-sm lg:max-w-md object-contain p-2 bg-white">
        </div>
      </div>

      <!-- Calculator -->
      <div class="bg-off-white rounded-3xl p-6 md:p-10 mb-12 border border-border w-full reveal delay-300 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.05)]">
        <DivorceCalculator client:visible />
      </div>

      <!-- Artykuł SEO -->
      <article class="prose prose-navy max-w-3xl mx-auto reveal">
        <h2>Ile kosztuje rozwód? — Szczegółowy przewodnik</h2>
        <p>
          Koszty postępowania rozwodowego w Polsce składają się z kilku elementów. Wbrew powszechnemu
          przekonaniu, nie jest to tylko stała opłata sądowa — ostateczna suma zależy od trybu sprawy,
          liczby spornych kwestii i wyboru pełnomocnika.
        </p>

        <h3>Opłata sądowa za rozwód</h3>
        <p>
          Zgodnie z <strong>art. 26 ust. 1 pkt 1 ustawy o kosztach sądowych w sprawach cywilnych (UKSC)</strong>,
          opłata sądowa od pozwu o rozwód wynosi <strong>600 zł</strong>. Jest to opłata stała,
          niezależna od wartości majątku stron.
        </p>
        <p>
          <strong>Ważne:</strong> jeśli sąd orzeknie rozwód bez orzekania o winie (na zgodny wniosek obu stron),
          strona powodowa otrzymuje <strong>zwrot 300 zł</strong> (połowa opłaty) na podstawie
          art. 79 ust. 1 pkt 1 UKSC.
        </p>

        <h3>Honorarium radcy prawnego lub adwokata</h3>
        <p>
          Minimalne stawki wynagrodzenia pełnomocnika w sprawach o rozwód określa rozporządzenie
          Ministra Sprawiedliwości z 22 X 2015 r.:
        </p>
        <ul>
          <li>Sprawa bez dzieci: min. 720 zł (§ 8 pkt 90 rozporządzenia)</li>
          <li>Sprawa z dziećmi: min. 1 080 zł</li>
        </ul>
        <p>
          W praktyce rynkowej (Wrocław 2025) honorarium wynosi od <strong>3 000 zł</strong> za
          nieskomplikowaną sprawę do <strong>15 000 zł i więcej</strong> przy spornym podziale
          majątku i walce o opiekę nad dziećmi.
        </p>

        <h3>Koszty dodatkowe</h3>
        <ul>
          <li><strong>Biegły psycholog</strong> (jeśli sąd zleci przy sporze o dzieci): 700–2 500 zł</li>
          <li><strong>Podział majątku</strong>: opłata 300 zł (zgodny) lub 1 000 zł (sporny)</li>
          <li><strong>Biegły majątkowy</strong> (wycena nieruchomości): 1 000–5 000 zł</li>
        </ul>

        <h3>Jak skrócić czas i obniżyć koszty?</h3>
        <p>
          Najskuteczniejszą metodą obniżenia kosztów jest <strong>mediacja</strong>. Przy zawarciu
          ugody mediacyjnej sąd może zwrócić nawet 3/4 uiszczonej opłaty (art. 79 ust. 1 pkt 2 UKSC).
          Mediacja pozwala też skrócić czas postępowania o kilka miesięcy.
        </p>
      </article>

      <!-- FAQ -->
      <section class="mt-12 reveal" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="font-serif text-2xl text-navy mb-6">Często zadawane pytania</h2>
        <div class="space-y-4">
          {[
            { q: 'Czy mogę złożyć pozew o rozwód bez prawnika?', a: 'Tak, nie ma obowiązku posiadania pełnomocnika. Jednak przy sporze o majątek lub dzieci profesjonalna pomoc znacznie zwiększa szanse na korzystny wyrok.' },
            { q: 'Kiedy sąd nie orzeka o winie?', a: 'Na zgodny wniosek obu małżonków, złożony w toku postępowania. Sąd pomija badanie winy i orzeka wyłącznie fakt rozpadu pożycia.' },
            { q: 'Czy koszty można rozłożyć?', a: 'Opłatę sądową płaci się przy składaniu pozwu. Honorarium prawnika często można negocjować — możliwa jest zaliczka + rozliczenie po sprawie.' },
            { q: 'Co jeśli nie stać mnie na opłatę?', a: 'Możesz złożyć wniosek o zwolnienie z kosztów sądowych (art. 102 UKSC). Sąd bada sytuację majątkową i może zwolnić w całości lub częściowo.' },
          ].map(item => (
            <details class="border border-border rounded-xl p-5 group">
              <summary class="cursor-pointer font-sans font-semibold text-navy flex justify-between items-center list-none">
                {item.q}
                <span class="text-gold text-xl ml-4">+</span>
              </summary>
              <p class="mt-3 font-sans text-text-muted text-sm leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <div class="mt-12 bg-navy rounded-3xl p-8 text-center reveal delay-200">
        <h2 class="font-serif text-2xl text-white mb-3">Nie wiesz ile zapłacisz w swojej sprawie?</h2>
        <p class="font-sans text-white opacity-80 mb-6 max-w-lg mx-auto">
          Każda sprawa o rozwód jest inna. Umów bezpłatną rozmowę wstępną — ocenimy Twoją sytuację i podamy konkretny kosztorys.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540;">Umów konsultację</a>
          <a href="tel:+48609366160" class="inline-block px-5 py-2.5 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg border-2 border-white/60 text-white hover:bg-white/10 transition-colors">609 366 160</a>
        </div>
      </div>

    </div>
  </section>
</Layout>
