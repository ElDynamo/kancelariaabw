---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import InheritanceCalculator from '@components/tools/InheritanceCalculator.vue';

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
    { "@type": "ListItem", "position": 3, "name": "Kalkulator zachowku", "item": "https://kancelariaabw.pl/narzedzia/kalkulator-zachowku" },
  ]
};
const webAppSchema = {
  "@context": "https://schema.org", "@type": "WebApplication",
  "name": "Kalkulator Zachowku 2025", "url": "https://kancelariaabw.pl/narzedzia/kalkulator-zachowku",
  "applicationCategory": "LegalService", "description": "Bezpłatny kalkulator zachowku według KC art. 991. Oblicz należny zachowek biorąc pod uwagę substrat zachowku, darowizny i udziały spadkowe.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" },
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW" }
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Komu przysługuje zachowek?", "acceptedAnswer": { "@type": "Answer", "text": "Zachowek przysługuje zstępnym (dzieciom, wnukom), małżonkowi i rodzicom spadkodawcy — ale tylko tym, którzy byliby powołani do dziedziczenia z ustawy (art. 991 KC)." } },
    { "@type": "Question", "name": "Ile wynosi zachowek?", "acceptedAnswer": { "@type": "Answer", "text": "Zachowek wynosi 1/2 udziału spadkowego przy dziedziczeniu ustawowym (lub 2/3 dla małoletnich i trwale niezdolnych do pracy). Mnoży się przez wartość czystego spadku powiększonego o darowizny." } },
    { "@type": "Question", "name": "Kiedy darowizny wlicza się do zachowku?", "acceptedAnswer": { "@type": "Answer", "text": "Darowizny na rzecz spadkobierców i osób uprawnionych do zachowku dolicza się bez limitu czasu. Darowizny na rzecz osób trzecich — tylko jeśli dokonano je w ciągu ostatnich 10 lat przed śmiercią (art. 994 KC)." } },
    { "@type": "Question", "name": "Kiedy przedawnia się zachowek?", "acceptedAnswer": { "@type": "Answer", "text": "Roszczenie o zachowek przedawnia się po 5 latach od ogłoszenia testamentu lub dowiedzenia się o otwarciu spadku (art. 1007 KC)." } }
  ]
};
---
<Layout
  title="Kalkulator Zachowku 2025 — ile wynosi zachowek po rodzicach?"
  description="Bezpłatny kalkulator zachowku wg KC art. 991. Oblicz należny zachowek: substrat, udziały, darowizny. Kancelaria ABW — prawo spadkowe Wrocław."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
    <StructuredData schema={webAppSchema} />
    <StructuredData schema={faqSchema} />
  </Fragment>
  <section class="section bg-white">
    <div class="container-site max-w-5xl">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-sans text-sm text-text-muted">
          <li><a href="/" class="hover:text-navy">Strona główna</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/narzedzia" class="hover:text-navy">Narzędzia prawne</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-navy">Kalkulator zachowku</li>
        </ol>
      </nav>
      <div class="flex items-center gap-2 mb-4">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Narzędzia prawne</span>
      </div>
      <h1 class="heading-xl mb-4">Kalkulator zachowku<br /><span class="text-gold">2025</span></h1>
      <p class="text-body text-lg max-w-2xl mb-10">
        Ile wynosi zachowek? Oblicz należny zachowek po rodzicach lub innych spadkodawcach.
        Kalkulator uwzględnia substrat zachowku, darowizny i udziały ustawowe wg KC art. 991.
      </p>
      <div class="bg-off-white rounded-3xl p-6 md:p-10 mb-12 border border-border">
        <InheritanceCalculator client:visible />
      </div>
      <article class="prose prose-navy max-w-2xl">
        <h2>Jak obliczyć zachowek? — Krok po kroku</h2>
        <p>Obliczenie zachowku wymaga ustalenia trzech elementów:</p>
        <ol>
          <li><strong>Substrat zachowku</strong> — wartość czystego spadku (aktywa minus długi) powiększona o darowizny podlegające doliczeniu</li>
          <li><strong>Udział ustawowy</strong> — jak duży udział przysługiwałby uprawnionemu przy dziedziczeniu z ustawy</li>
          <li><strong>Ułamek zachowku</strong> — 1/2 lub 2/3 udziału ustawowego (art. 991 KC)</li>
        </ol>
        <h3>Kluczowa kwestia: kiedy darowizny wlicza się do zachowku?</h3>
        <p>
          Darowizny dokonane na rzecz osób <strong>będących spadkobiercami lub uprawnionymi do zachowku</strong>
          doliczane są do substratu <strong>bez limitu czasowego</strong>. Dla osób trzecich — tylko
          darowizny z ostatnich 10 lat (art. 994 KC). To częsty punkt sporny w sprawach spadkowych.
        </p>
      </article>
      <div class="mt-12 rounded-3xl overflow-hidden" style="background: linear-gradient(135deg, #0f2540 0%, #1a3a5c 100%);">
        <div class="p-8 md:p-10 text-center">
          <h2 class="font-serif text-2xl md:text-3xl text-white mb-3">Spór o zachowek? Pomożemy.</h2>
          <p class="font-sans text-base text-white/80 mb-8 max-w-md mx-auto leading-relaxed">
            Sprawy o zachowek wymagają analizy całej historii majątkowej rodziny. Umów konsultację.
          </p>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/kontakt"
              class="inline-block px-6 py-3 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg"
              style="background:#c9a84c; color:#0f2540;">
              Umów konsultację
            </a>
            <a href="/uslugi/prawo-cywilne"
              class="inline-block px-6 py-3 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg border-2 border-white/60 text-white hover:bg-white/10 transition-colors">
              Prawo cywilne
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
