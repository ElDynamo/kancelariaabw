---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import SectionLabel from '@components/ui/SectionLabel.astro';
import ToolCTA from '@components/ui/ToolCTA.astro';
import StatuteLimitationsCalculator from '@components/tools/StatuteLimitationsCalculator.vue';

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
    { "@type": "ListItem", "position": 3, "name": "Kalkulator przedawnienia", "item": "https://kancelariaabw.pl/narzedzia/przedawnienie-roszczen" },
  ]
};
const webAppSchema = {
  "@context": "https://schema.org", "@type": "WebApplication",
  "name": "Kalkulator Przedawnienia Roszczeń 2025",
  "url": "https://kancelariaabw.pl/narzedzia/przedawnienie-roszczen",
  "applicationCategory": "LegalService",
  "description": "Kalkulator terminu przedawnienia roszczeń. Sprawdź kiedy dług się przedawnia — 6 lat lub 3 lata. Uwzględnia nowelizację KC 2018 i zasadę 31 grudnia.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" },
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW" }
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Kiedy dług się przedawnia?", "acceptedAnswer": { "@type": "Answer", "text": "Po nowelizacji KC z 2018 r. ogólny termin przedawnienia wynosi 6 lat (wcześniej 10 lat). Roszczenia z działalności gospodarczej i świadczenia okresowe — 3 lata. Termin upada zawsze 31 grudnia (art. 118 KC)." } },
    { "@type": "Question", "name": "Co to jest przerwanie biegu przedawnienia?", "acceptedAnswer": { "@type": "Answer", "text": "Bieg terminu przedawnienia przerywa się przez złożenie pozwu, uznanie długu przez dłużnika lub wszczęcie mediacji. Po przerwaniu termin biegnie od nowa (art. 123 KC)." } },
    { "@type": "Question", "name": "Czy sąd sprawdza przedawnienie z urzędu?", "acceptedAnswer": { "@type": "Answer", "text": "Od 2018 r. sąd uwzględnia przedawnienie z urzędu w sprawach z konsumentami. W sprawach między przedsiębiorcami — tylko na zarzut dłużnika." } }
  ]
};
---
<Layout
  title="Kalkulator Przedawnienia Roszczeń 2025 — kiedy dług się przedawnia?"
  description="Sprawdź kiedy roszczenie się przedawnia. Kalkulator przedawnienia wg KC art. 118 — terminy 6 lat i 3 lata, zasada 31 XII, przerwanie biegu. Darmowe narzędzie."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
    <StructuredData schema={webAppSchema} />
    <StructuredData schema={faqSchema} />
  </Fragment>
  <section class="section bg-white">
    <div class="container-site max-w-5xl">
      <Breadcrumb items={[
        { label: 'Strona główna', href: '/' },
        { label: 'Narzędzia prawne', href: '/narzedzia' },
        { label: 'Przedawnienie roszczeń' },
      ]} />
      <SectionLabel text="Narzędzia prawne" class="mb-4 reveal" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-10">
        <div class="reveal delay-100">
          <h1 class="heading-xl mb-4">Kalkulator przedawnienia<br /><span class="text-gold">roszczeń 2025</span></h1>
          <p class="text-body text-lg max-w-2xl">
            Kiedy dług się przedawnia? Oblicz dokładną datę przedawnienia roszczenia — z uwzględnieniem
            nowelizacji KC z 2018 r. (skrócenie do 6 lat), zasady 31 grudnia i przerwania biegu.
          </p>
        </div>
        <div class="reveal delay-200 flex justify-center md:justify-end">
             <img src="/tools/limitation_graphic_pl_1772990335361.png" alt="Grafika wektorowa kalkulator przedawnienia roszczeń" class="rounded-[2.5rem] shadow-2xl shadow-navy/10 transform rotate-1 hover:rotate-0 transition-transform duration-500 w-full max-w-sm lg:max-w-md object-contain p-2 bg-white">
        </div>
      </div>
      <!-- Calculator -->
      <div class="md:bg-off-white md:rounded-3xl md:p-10 mb-12 md:border md:border-border w-full md:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.05)]">
        <StatuteLimitationsCalculator client:visible />
      </div>
      <article class="prose prose-navy max-w-3xl mx-auto reveal">
        <h2>Terminy przedawnienia po nowelizacji 2018</h2>
        <p>
          Ustawa z 13 IV 2018 r. (weszła w życie 9 VII 2018 r.) gruntownie zmieniła przepisy
          o przedawnieniu. Kluczowe zmiany:
        </p>
        <ul>
          <li>Ogólny termin: skrócony z <strong>10 do 6 lat</strong></li>
          <li>Koniec terminu zawsze <strong>31 grudnia</strong> (jeśli ≥ 2 lata)</li>
          <li>Sąd w sprawach konsumenckich bada przedawnienie <strong>z urzędu</strong></li>
        </ul>
        <h3>Zasada 31 grudnia — co to oznacza?</h3>
        <p>
          Jeśli roszczenie wymagało zapłaty np. 1 marca 2022 r., a termin przedawnienia to 6 lat,
          to teoretycznie upływa 1 marca 2028 r., ale na mocy art. 118 KC zd. 2 — faktycznie
          dopiero <strong>31 grudnia 2028 r.</strong>. To ważne przy planowaniu podjęcia działań.
        </p>
      </article>

      <ToolCTA
        title="Masz wątpliwości co do przedawnienia?"
        description="Przedawnienie to jeden z najczęstszych błędów prawnych — skonsultuj swoją sprawę, zanim upłynie termin."
        secondaryText="Prawo cywilne"
        secondaryHref="/uslugi/prawo-cywilne"
      />
    </div>
  </section>
</Layout>
