---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const tools = [
  {
    slug: 'koszty-rozwodu',
    title: 'Kalkulator kosztów rozwodu',
    desc: 'Oblicz szacunkowy koszt postępowania — opłata sądowa, honorarium prawnika, podział majątku.',
    fraza: 'ile kosztuje rozwód',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 9l9-6 9 6M6 12l-3 6h6l-3-6zm12 0l-3 6h6l-3-6z"/></svg>`,
    kolor: 'from-navy to-slate-700',
  },
  {
    slug: 'kalkulator-alimentow',
    title: 'Kalkulator alimentów',
    desc: 'Szacunkowa kwota alimentów wg dochodów i potrzeb dziecka. Opiera się na tablicach MS 2022.',
    fraza: 'jak wyliczyć alimenty',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    kolor: 'from-slate-700 to-navy',
  },
  {
    slug: 'oplaty-sadowe',
    title: 'Kalkulator opłat sądowych',
    desc: 'Ile kosztuje pozew? Sprawdź opłatę stosunkową lub stałą według aktualnego UKSC 2025.',
    fraza: 'opłata sądowa kalkulator',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="22" x2="22" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>`,
    kolor: 'from-navy to-slate-800',
  },
  {
    slug: 'kalkulator-zachowku',
    title: 'Kalkulator zachowku',
    desc: 'Oblicz należny zachowek — substrat, darowizny, ułamek 1/2 lub 2/3 (art. 991 KC).',
    fraza: 'ile wynosi zachowek',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    kolor: 'from-slate-800 to-navy',
  },
  {
    slug: 'przedawnienie-roszczen',
    title: 'Kalkulator przedawnienia',
    desc: 'Kiedy dług się przedawnia? Oblicz datę z uwzględnieniem reguły 31 XII i przerwania biegu.',
    fraza: 'kiedy przedawnia się dług',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    kolor: 'from-navy to-slate-700',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
  ]
};
---

<Layout
  title="Bezpłatne Narzędzia Prawne — Kalkulatory 2025 | Kancelaria ABW"
  description="Bezpłatne kalkulatory prawne: koszty rozwodu, alimenty, zachowek, opłaty sądowe, przedawnienie. Aktualne przepisy 2025. Kancelaria Prawna ABW Wrocław."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="container-site max-w-5xl">

      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-sans text-sm text-text-muted">
          <li><a href="/" class="hover:text-navy">Strona główna</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-navy">Narzędzia prawne</li>
        </ol>
      </nav>

      <div class="flex items-center gap-2 mb-4">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Bezpłatne narzędzia</span>
      </div>
      <h1 class="heading-xl mb-4">Kalkulatory prawne<br /><span class="text-gold">online 2025</span></h1>
      <p class="text-body text-lg max-w-2xl mb-12">
        Bezpłatne narzędzia opracowane przez Kancelarię Prawną ABW na podstawie aktualnych przepisów
        polskiego prawa. Oblicz orientacyjne koszty i terminy — szybko, bez rejestracji.
      </p>

      <!-- Siatka narzędzi -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {tools.map(tool => (
          <a href={`/narzedzia/${tool.slug}`}
            class="group relative overflow-hidden rounded-2xl border border-border bg-white hover:border-navy hover:shadow-lg transition-all duration-300 flex flex-col">
            <div class={`bg-gradient-to-br ${tool.kolor} p-6 flex items-center justify-between`}>
              <div class="text-white opacity-90 group-hover:opacity-100 transition-opacity">
                <Fragment set:html={tool.icon} />
              </div>
              <span class="text-xs font-sans uppercase tracking-widest text-white opacity-60">→</span>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h2 class="font-serif text-lg text-navy mb-2 group-hover:text-gold transition-colors">
                {tool.title}
              </h2>
              <p class="font-sans text-sm text-text-muted leading-relaxed flex-1">{tool.desc}</p>
              <div class="mt-4 flex items-center gap-2">
                <span class="text-xs text-gold font-sans">Szukasz: „{tool.fraza}"?</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Info section -->
      <div class="bg-off-white rounded-2xl p-8 border border-border mb-12">
        <h2 class="font-serif text-xl text-navy mb-4">O naszych kalkulatorach</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-sans text-sm text-text-muted">
          <div>
            <p class="font-semibold text-navy mb-1">✅ Aktualne przepisy</p>
            <p>Kalkulatory uwzględniają stan prawny na 2025 r., w tym nowelizację UKSC z IX 2025 i KC z 2018 r.</p>
          </div>
          <div>
            <p class="font-semibold text-navy mb-1">⚡ Bez rejestracji</p>
            <p>Narzędzia działają w przeglądarce. Nie przechowujemy żadnych danych — pełna prywatność.</p>
          </div>
          <div>
            <p class="font-semibold text-navy mb-1">⚖️ Wyniki orientacyjne</p>
            <p>Kalkulatory dają szacunkowe wyniki. Dokładna kwota zawsze zależy od okoliczności danej sprawy.</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-navy rounded-3xl p-8 text-center">
        <h2 class="font-serif text-2xl text-white mb-3">Potrzebujesz dokładnej analizy swojej sprawy?</h2>
        <p class="font-sans text-white opacity-80 mb-6 max-w-lg mx-auto">
          Kalkulatory to dobry punkt startowy. Umów bezpłatną rozmowę — ocenimy Twoją sytuację i podamy konkretny plan.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540;">Umów konsultację</a>
          <a href="tel:+48609366160" class="inline-block px-5 py-2.5 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg border-2 border-white/60 text-white hover:bg-white/10 transition-colors">609 366 160</a>
        </div>
      </div>

    </div>
  </section>
</Layout>
