---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const tools = [
  {
    slug: 'koszty-rozwodu',
    title: 'Kalkulator kosztów rozwodu',
    desc: 'Oblicz szacunkowy koszt postępowania — opłata sądowa, honorarium prawnika, podział majątku.',
    fraza: 'ile kosztuje rozwód',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 9l9-6 9 6M6 12l-3 6h6l-3-6zm12 0l-3 6h6l-3-6z"/></svg>`,
    image: '/tools/divorce_cost_graphic_pl_1772990272156.png',
  },
  {
    slug: 'kalkulator-alimentow',
    title: 'Kalkulator alimentów',
    desc: 'Szacunkowa kwota alimentów wg dochodów i potrzeb dziecka. Opiera się na tablicach MS 2022.',
    fraza: 'jak wyliczyć alimenty',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    image: '/tools/alimony_graphic_pl_1772990288262.png',
  },
  {
    slug: 'oplaty-sadowe',
    title: 'Kalkulator opłat sądowych',
    desc: 'Ile kosztuje pozew? Sprawdź opłatę stosunkową lub stałą według aktualnego UKSC 2025.',
    fraza: 'opłata sądowa kalkulator',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="22" x2="22" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>`,
    image: '/tools/court_fees_graphic_pl_1772990300994.png',
  },
  {
    slug: 'kalkulator-zachowku',
    title: 'Kalkulator zachowku',
    desc: 'Oblicz należny zachowek — substrat, darowizny, ułamek 1/2 lub 2/3 (art. 991 KC).',
    fraza: 'ile wynosi zachowek',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    image: '/tools/inheritance_graphic_pl_1772990320132.png',
  },
  {
    slug: 'przedawnienie-roszczen',
    title: 'Kalkulator przedawnienia',
    desc: 'Kiedy dług się przedawnia? Oblicz datę z uwzględnieniem reguły 31 XII i przerwania biegu.',
    fraza: 'kiedy przedawnia się dług',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    image: '/tools/limitation_graphic_pl_1772990335361.png',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
  ]
};
---

<Layout
  title="Bezpłatne Narzędzia Prawne — Kalkulatory 2025 | Kancelaria ABW"
  description="Bezpłatne kalkulatory prawne: koszty rozwodu, alimenty, zachowek, opłaty sądowe, przedawnienie. Aktualne przepisy 2025. Kancelaria Prawna ABW Wrocław."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="container-site max-w-5xl">

      <nav aria-label="Breadcrumb" class="mb-10 reveal">
        <ol class="flex items-center gap-2 font-sans text-sm text-text-muted">
          <li><a href="/" class="hover:text-navy transition-colors">Strona główna</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-navy font-medium">Narzędzia prawne</li>
        </ol>
      </nav>

      <div class="flex items-center gap-2 mb-4 reveal delay-100">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold font-semibold">Bezpłatne narzędzia</span>
      </div>
      <h1 class="heading-xl mb-6 reveal delay-200">Kalkulatory prawne<br /><span class="text-gold">online 2025</span></h1>
      <p class="text-body text-xl max-w-3xl mb-16 reveal delay-300 leading-relaxed">
        Bezpłatne narzędzia opracowane przez Kancelarię Prawną ABW na podstawie aktualnych przepisów
        polskiego prawa. Oblicz orientacyjne koszty i terminy — szybko, bez rejestracji.
      </p>

      <!-- Siatka narzędzi -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-24">
        {tools.map((tool, index) => (
          <a href={`/narzedzia/${tool.slug}`}
            class={`group relative overflow-hidden bg-white rounded-[2rem] border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 hover:border-gold/30 transition-all duration-500 flex flex-col transform hover:-translate-y-1 reveal delay-${(index % 3 + 1) * 100}`}>
            
            <div class="p-8 flex flex-col flex-1">
              <div class="flex flex-col gap-6 mb-5">
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl shadow-sm border border-slate-100 overflow-hidden shrink-0 group-hover:border-gold/30 transition-colors duration-300 bg-slate-50">
                  <img src={tool.image} alt={tool.title} loading="lazy" class="w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700 ease-out" />
                </div>
                <h2 class="font-serif text-xl md:text-2xl text-navy group-hover:text-gold transition-colors duration-300 leading-tight">
                  {tool.title}
                </h2>
              </div>
              
              <p class="font-sans text-sm text-navy/60 leading-relaxed font-medium flex-1 mb-8">
                {tool.desc}
              </p>
              
              <div class="mt-auto border-t-2 border-slate-100 pt-5 flex items-center justify-between">
                <span class="inline-flex items-center gap-2 text-[11px] font-sans font-bold tracking-[0.15em] uppercase text-navy group-hover:text-gold transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  Uruchom
                </span>
                <span class="text-[9px] font-sans font-bold text-navy/20 uppercase tracking-[0.2em] px-3 py-1 rounded-full bg-slate-50 truncate max-w-[120px]">
                  {tool.fraza}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Info section -->
      <div class="mb-24 reveal">
        <div class="flex items-center gap-2 mb-8">
          <span class="h-px w-8 bg-gold"></span>
          <h2 class="font-serif text-3xl text-navy">Dlaczego warto używać naszych narzędzi?</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 hover:*:border-gold/40">
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Aktualne przepisy</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Kalkulatory uwzględniają stan prawny obowiązujący w 2025 r., w tym nowelizację UKSC z września 2025 i reguły z 2018 r.</p>
          </div>
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1 hover:border-gold/40">
            <div class="w-14 h-14 rounded-2xl bg-gold/10 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M8 11h8"/><path d="M12 15V7"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Pełna prywatność</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Narzędzia działają całkowicie w Twojej przeglądarce i nie wymagają rejestracji. Nie gromadzimy wpisywanych danych.</p>
          </div>
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Wyniki orientacyjne</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Pamiętaj, że obliczenia przedstawiają rzetelny ale tylko szacunkowy zarys sytuacji do obrania kierunku swojej sprawy.</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-navy rounded-[2.5rem] p-10 md:p-14 text-center reveal border border-white/10 shadow-[0_20px_50px_-12px_rgba(15,37,64,0.3)] relative overflow-hidden">
        <!-- Dekoracyjne koła -->
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[30rem] h-[30rem] bg-gold/5 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-[20rem] h-[20rem] bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
        
        <div class="relative z-10 w-full flex flex-col items-center">
            <h2 class="font-serif text-3xl md:text-4xl text-white mb-5">Potrzebujesz dokładnej analizy swojej sprawy?</h2>
            <p class="font-sans text-white/80 mb-10 max-w-2xl text-lg md:text-xl font-light">
              Kalkulatory to doskonały punkt wyjścia. Umów bezpłatną, wstępną rozmowę — przeanalizujemy Twoją unikalną sytuację krok po kroku.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540;">Skontaktuj się z nami</a>
              <a href="tel:+48609366160" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 font-sans font-semibold text-sm uppercase tracking-wide rounded-xl border border-white/30 text-white hover:bg-white/10 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                609 366 160
              </a>
            </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
