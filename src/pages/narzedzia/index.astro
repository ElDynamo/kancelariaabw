---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import SectionLabel from '@components/ui/SectionLabel.astro';
import ToolCTA from '@components/ui/ToolCTA.astro';
import { getCollection, getEntry } from 'astro:content';

const toolsInfoEntries = await getCollection('toolsInfo');
const tools = toolsInfoEntries.map(entry => ({
  ...entry.data,
  slug: entry.id
}));

const toolsIndexEntry = await getEntry('singletons', 'toolsIndex');
const hero = toolsIndexEntry?.data?.hero || { 
  title: 'Kalkulatory prawne online 2025', 
  description: 'Bezpłatne narzędzia opracowane przez Kancelarię Prawną ABW.' 
};

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
  ]
};
---

<Layout
  title="Bezpłatne Narzędzia Prawne — Kalkulatory 2025 | Kancelaria ABW"
  description="Bezpłatne kalkulatory prawne: koszty rozwodu, alimenty, zachowek, opłaty sądowe, przedawnienie. Aktualne przepisy 2025. Kancelaria Prawna ABW Wrocław."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="w-full max-w-7xl mx-auto px-6 lg:px-8 max-w-5xl">

      <Breadcrumb items={[
        { label: 'Strona główna', href: '/' },
        { label: 'Narzędzia prawne' },
      ]} />

      <SectionLabel text="Bezpłatne narzędzia" class="mb-4 reveal delay-100" />
      <h1 class="heading-xl mb-6 reveal delay-200" set:html={hero.title}></h1>
      <p class="text-body text-xl max-w-3xl mb-16 reveal delay-300 leading-relaxed">
        {hero.description}
      </p>

      <!-- Siatka narzędzi -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-24">
        {tools.map((tool, index) => (
          <a href={`/narzedzia/${tool.slug}`}
            class={`group relative overflow-hidden bg-white rounded-[2rem] border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 hover:border-gold/30 transition-all duration-500 flex flex-col transform hover:-translate-y-1 reveal delay-${(index % 3 + 1) * 100}`}>
            
            <div class="p-8 flex flex-col flex-1">
              <div class="flex flex-col gap-6 mb-5">
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl shadow-sm border border-slate-100 overflow-hidden shrink-0 group-hover:border-gold/30 transition-colors duration-300 bg-slate-50">
                  <img src={tool.image} alt={tool.title} loading="lazy" class="w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700 ease-out" />
                </div>
                <h2 class="font-serif text-xl md:text-2xl text-navy group-hover:text-gold transition-colors duration-300 leading-tight">
                  {tool.title}
                </h2>
              </div>
              
              <p class="font-sans text-sm text-navy/60 leading-relaxed font-medium flex-1 mb-8">
                {tool.desc}
              </p>
              
              <div class="mt-auto border-t-2 border-slate-100 pt-5 flex items-center justify-between">
                <span class="inline-flex items-center gap-2 text-[11px] font-sans font-bold tracking-[0.15em] uppercase text-navy group-hover:text-gold transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  Uruchom
                </span>
                <span class="text-[9px] font-sans font-bold text-navy/20 uppercase tracking-[0.2em] px-3 py-1 rounded-full bg-slate-50 truncate max-w-[120px]">
                  {tool.fraza}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Info section -->
      <div class="mb-24 reveal">
        <div class="flex items-center gap-2 mb-8">
          <span class="h-px w-8 bg-gold"></span>
          <h2 class="font-serif text-3xl text-navy">Dlaczego warto używać naszych narzędzi?</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 hover:*:border-gold/40">
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Aktualne przepisy</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Kalkulatory uwzględniają stan prawny obowiązujący w 2025 r., w tym nowelizację UKSC z września 2025 i reguły z 2018 r.</p>
          </div>
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1 hover:border-gold/40">
            <div class="w-14 h-14 rounded-2xl bg-gold/10 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M8 11h8"/><path d="M12 15V7"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Pełna prywatność</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Narzędzia działają całkowicie w Twojej przeglądarce i nie wymagają rejestracji. Nie gromadzimy wpisywanych danych.</p>
          </div>
          <div class="bg-white rounded-[2rem] p-8 border-2 border-slate-100 shadow-sm hover:shadow-xl hover:shadow-navy/5 transition-all duration-500 hover:-translate-y-1">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center text-gold mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-navy mb-3">Wyniki orientacyjne</h3>
            <p class="font-sans text-sm text-navy/60 font-medium leading-relaxed">Pamiętaj, że obliczenia przedstawiają rzetelny ale tylko szacunkowy zarys sytuacji do obrania kierunku swojej sprawy.</p>
          </div>
        </div>
      </div>

      <ToolCTA
        title="Potrzebujesz dokładnej analizy swojej sprawy?"
        description="Kalkulatory to doskonały punkt wyjścia. Umów bezpłatną, wstępną rozmowę — przeanalizujemy Twoją unikalną sytuację krok po kroku."
        ctaText="Skontaktuj się z nami"
        secondaryText="609 366 160"
        secondaryHref="tel:+48609366160"
      />

    </div>
  </section>
</Layout>
