---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import SectionLabel from '@components/ui/SectionLabel.astro';
import FAQAccordion from '@components/ui/FAQAccordion.astro';
import ToolCTA from '@components/ui/ToolCTA.astro';
import AlimonyCalculator from '@components/tools/AlimonyCalculator.vue';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Narzędzia prawne", "item": "https://kancelariaabw.pl/narzedzia" },
    { "@type": "ListItem", "position": 3, "name": "Kalkulator alimentów", "item": "https://kancelariaabw.pl/narzedzia/kalkulator-alimentow" },
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Kalkulator Alimentów 2025",
  "url": "https://kancelariaabw.pl/narzedzia/kalkulator-alimentow",
  "applicationCategory": "LegalService",
  "description": "Bezpłatny kalkulator alimentów. Oblicz szacunkową kwotę alimentów na dziecko według zasad KRiO art. 135 i tablic Ministerstwa Sprawiedliwości.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" },
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Jak sąd oblicza alimenty?", "acceptedAnswer": { "@type": "Answer", "text": "Sąd nie stosuje stałego wzoru. Ocenia usprawiedliwione potrzeby dziecka i możliwości zarobkowe zobowiązanego (art. 135 KRiO). Bierze pod uwagę dochody, majątek, stan zdrowia i starania osobiste każdego z rodziców." } },
    { "@type": "Question", "name": "Czy 800+ wpływa na wysokość alimentów?", "acceptedAnswer": { "@type": "Answer", "text": "Nie. Świadczenie wychowawcze 800+ nie zmniejsza zobowiązania alimentacyjnego ani nie jest wliczane do kosztów utrzymania dziecka pokrywanych przez rodziców (KRiO art. 135 § 3, dodany nowelizacją z 2019 r.)." } },
    { "@type": "Question", "name": "Czy można zmienić alimenty po wyroku?", "acceptedAnswer": { "@type": "Answer", "text": "Tak — przy zmianie stosunków (art. 138 KRiO). Przesłanką jest m.in. wzrost potrzeb dziecka, zmiana dochodów zobowiązanego lup uprawnionego, ukończenie 18 roku życia, podjęcie pracy przez dziecko." } },
    { "@type": "Question", "name": "Od kiedy liczy się termin płatności alimentów?", "acceptedAnswer": { "@type": "Answer", "text": "Alimenty zasądzane są od dnia wniesienia pozwu lub od dnia zawarcia ugody mediacyjnej. Sąd może zasądzić alimenty wstecz, jednak praktycznie nie wstecz niż od dnia pozwu." } },
    { "@type": "Question", "name": "Co jeśli zobowiązany nie płaci alimentów?", "acceptedAnswer": { "@type": "Answer", "text": "Można złożyć wniosek do komornika sądowego. Jeśli egzekucja jest bezskuteczna i dochód rodziny nie przekracza 900 zł/os., dziecko może ubiegać się o świadczenie z Funduszu Alimentacyjnego (do 1 000 zł/mies. od X 2024)." } }
  ]
};

const pageFaqItems = [
  { question: 'Czy można żądać alimentów wstecz?', answer: 'W praktyce sądy zasądzają alimenty od dnia złożenia pozwu. Wyjątkowo możliwe jest zasądzenie za wcześniejszy okres, jeśli powód udowodni zaległe, niezaspokojone potrzeby.' },
  { question: 'Jak często można żądać podwyższenia alimentów?', answer: 'Nie ma minimalnego odstępu czasowego. Wniosek jest uzasadniony gdy nastąpi zmiana stosunków — wzrost potrzeb dziecka lub poprawa sytuacji zobowiązanego (art. 138 KRiO).' },
  { question: 'Czy student może dostać alimenty?', answer: 'Tak — obowiązek alimentacyjny nie wygasa automatycznie z chwilą ukończenia 18 lat. Trwa, dopóki dziecko (student) nie jest w stanie się samodzielnie utrzymać.' },
];
---

<Layout
  title="Kalkulator Alimentów 2025 — ile wynoszą alimenty na dziecko?"
  description="Bezpłatny kalkulator alimentów. Oblicz szacunkową kwotę alimentów na dziecko wg KRiO art. 135 i tablic Ministerstwa Sprawiedliwości. Alimenty 2025 Wrocław."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumbSchema} />
    <StructuredData schema={webAppSchema} />
    <StructuredData schema={faqSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="w-full max-w-7xl mx-auto px-6 lg:px-8 max-w-5xl">

      <Breadcrumb items={[
        { label: 'Strona główna', href: '/' },
        { label: 'Narzędzia prawne', href: '/narzedzia' },
        { label: 'Kalkulator alimentów' },
      ]} />

      <SectionLabel text="Narzędzia prawne" class="mb-4 reveal" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center mb-10">
        <div class="reveal delay-100">
          <h1 class="heading-xl mb-4">
            Kalkulator alimentów<br />
            <span class="text-gold">na dziecko 2025</span>
          </h1>
          <p class="text-body text-lg max-w-2xl">
            Ile wynoszą alimenty? Oblicz szacunkową kwotę świadczeń alimentacyjnych na dziecko na podstawie
            dochodów zobowiązanego i potrzeb dziecka. Wyniki opierają się na art. 135 KRiO i tablicach
            orientacyjnych Ministerstwa Sprawiedliwości.
          </p>
        </div>
        <div class="reveal delay-200 flex justify-center md:justify-end">
             <img src="/tools/alimony_graphic_pl_1772990288262.png" alt="Grafika wektorowa kalkulator alimentów" class="rounded-[2.5rem] shadow-2xl shadow-navy/10 transform rotate-1 hover:rotate-0 transition-transform duration-500 w-full max-w-sm lg:max-w-md object-contain p-2 bg-white">
        </div>
      </div>

      <div class="md:bg-off-white md:rounded-3xl md:p-10 mb-12 md:border md:border-border w-full md:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.05)]">
        <AlimonyCalculator client:visible />
      </div>

      <article class="prose prose-navy max-w-3xl mx-auto reveal">
        <h2>Jak oblicza się alimenty w Polsce?</h2>
        <p>
          W polskim prawie nie istnieje stały wzór ani przelicznik procentowy dla alimentów.
          Sąd każdorazowo ocenia dwie przesłanki określone w <strong>art. 135 § 1 Kodeksu
          rodzinnego i opiekuńczego</strong>:
        </p>
        <ul>
          <li><strong>Usprawiedliwione potrzeby dziecka</strong> — wyżywienie, ubranie, edukacja, leczenie, rozrywka, mieszkanie</li>
          <li><strong>Zarobkowe i majątkowe możliwości zobowiązanego</strong> — nie tylko faktyczne dochody, ale też potencjał zarobkowy</li>
        </ul>

        <h3>Tablice alimentacyjne Ministerstwa Sprawiedliwości</h3>
        <p>
          W 2022 r. Ministerstwo Sprawiedliwości opublikowało <strong>tablice alimentacyjne</strong>
          jako narzędzie pomocnicze dla sądów i rodziców. Wskazują one orientacyjne poziomy alimentów
          w zależności od dochodu zobowiązanego i wieku dziecka. Tablice <strong>nie mają mocy prawnej</strong>
          — sąd nie jest nimi związany, jednak w praktyce stanowią punkt odniesienia przy ustalaniu
          wysokości świadczenia.
        </p>

        <h3>Świadczenie 800+ a alimenty</h3>
        <p>
          Nowelizacja KRiO z 2019 r. dodała art. 135 § 3, który jednoznacznie wyklucza zaliczanie
          świadczenia 800+ (dawniej 500+) do kosztów utrzymania dziecka pokrywanych przez rodziców.
          Pobieranie 800+ nie zmniejsza alimentów.
        </p>

        <h3>Opieka naprzemienna a alimenty</h3>
        <p>
          Przy opiece naprzemiennej (dziecko spędza równy czas u obojga rodziców) sąd może obniżyć
          alimenty lub w ogóle ich nie zasądzać, jeśli oboje rodzice ponoszą koszty bezpośrednio
          w równym stopniu. W praktyce często pozostają alimenty w niższej wysokości.
        </p>
      </article>

      <FAQAccordion items={pageFaqItems} title="Często zadawane pytania" class="!bg-transparent !py-0 mt-12" />

      <ToolCTA
        title="Potrzebujesz pomocy w sprawie alimentacyjnej?"
        description="Sprawy o alimenty wymagają precyzyjnego udokumentowania potrzeb dziecka i możliwości drugiej strony."
        secondaryText="Prawo rodzinne"
        secondaryHref="/uslugi/prawo-rodzinne"
      />

    </div>
  </section>
</Layout>
