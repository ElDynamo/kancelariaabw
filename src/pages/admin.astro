---
export const prerender = false;

const ADMIN_PASSWORD = 'abw2024admin';
const isAuthed = Astro.request.headers.get('cookie')?.includes('admin_auth=true');
const isPreview = Astro.request.headers.get('cookie')?.includes('preview=true');

if (Astro.request.method === 'POST') {
  const body = await Astro.request.formData();
  const password = body.get('password');
  if (password === ADMIN_PASSWORD) {
    return new Response(null, {
      status: 302,
      headers: {
        'Set-Cookie': 'admin_auth=true; Path=/; HttpOnly; Max-Age=86400',
        Location: '/admin'
      }
    });
  } else {
    return new Response(null, { status: 302, headers: { Location: '/admin?error=1' } });
  }
}

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Panel Administracyjny — Kancelaria ABW</title>
  <meta name="robots" content="noindex, nofollow" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', system-ui, sans-serif; background: #0a1628; min-height: 100vh; color: #fff; display: flex; align-items: center; justify-content: center; }
    
    /* ── LOGIN ── */
    .login { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: 3rem 2.5rem; width: 100%; max-width: 400px; }
    .brand { font-size: 1.5rem; color: #c9a84c; margin-bottom: .25rem; }
    .brand-sub { font-size: .7rem; color: rgba(255,255,255,.35); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 2rem; }
    input[type=password] { width: 100%; padding: .875rem 1rem; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.15); border-radius: 10px; color: #fff; font-family: inherit; font-size: 1rem; outline: none; margin-bottom: 1rem; }
    input[type=password]:focus { border-color: #c9a84c; }
    .btn-primary { width: 100%; padding: .875rem; background: #c9a84c; color: #0a1628; font-family: inherit; font-weight: 700; font-size: .9rem; border: none; border-radius: 10px; cursor: pointer; }
    .btn-primary:hover { background: #b8943f; }
    .error { background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.25); color: #fca5a5; padding: .75rem 1rem; border-radius: 8px; font-size: .82rem; margin-bottom: 1rem; }

    /* ── DASHBOARD ── */
    .dash { width: 100%; max-width: 820px; padding: 2rem 1.25rem; }
    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .brand-sm { font-size: 1.25rem; color: #c9a84c; }
    .brand-sm span { display: block; font-size: .68rem; color: rgba(255,255,255,.3); text-transform: uppercase; letter-spacing: .1em; margin-top: .15rem; }
    .logout { font-size: .78rem; color: rgba(255,255,255,.4); text-decoration: none; padding: .45rem .9rem; border: 1px solid rgba(255,255,255,.1); border-radius: 7px; }
    .logout:hover { color: #fff; border-color: rgba(255,255,255,.25); }

    /* Status box */
    .status-box { border-radius: 14px; padding: 1.25rem 1.5rem; margin-bottom: 1.75rem; }
    .status-box.preview { background: rgba(201,168,76,.08); border: 1px solid rgba(201,168,76,.3); }
    .status-box.normal { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); }
    .status-header { display: flex; align-items: center; gap: .6rem; margin-bottom: .4rem; }
    .pulse { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; animation: blink 2s infinite; }
    .pulse.gold { background: #c9a84c; }
    .pulse.gray { background: rgba(255,255,255,.3); }
    @keyframes blink { 0%,100% { opacity:1 } 50% { opacity:.3 } }
    .status-title { font-weight: 700; font-size: .9rem; color: #c9a84c; }
    .status-title.gray { color: rgba(255,255,255,.6); }
    .status-desc { font-size: .82rem; color: rgba(255,255,255,.5); line-height: 1.55; }
    .status-actions { display: flex; gap: .6rem; margin-top: .9rem; flex-wrap: wrap; }

    /* Buttons */
    .btn { padding: .55rem 1.1rem; border-radius: 8px; font-family: inherit; font-size: .78rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; display: inline-flex; align-items: center; gap: .4rem; transition: all .15s; }
    .btn-gold { background: #c9a84c; color: #0a1628; }
    .btn-gold:hover { background: #b8943f; }
    .btn-outline-gold { background: transparent; color: #c9a84c; border: 1.5px solid rgba(201,168,76,.4); }
    .btn-outline-gold:hover { background: rgba(201,168,76,.08); border-color: #c9a84c; }
    .btn-ghost { background: transparent; color: rgba(255,255,255,.45); border: 1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { color: rgba(255,255,255,.8); border-color: rgba(255,255,255,.25); }

    /* Preview links sub-section */
    .see-links { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: .75rem; }
    .see-link { padding: .4rem .85rem; border-radius: 6px; font-size: .74rem; font-weight: 500; text-decoration: none; background: rgba(255,255,255,.06); color: rgba(255,255,255,.7); border: 1px solid rgba(255,255,255,.1); }
    .see-link:hover { background: rgba(255,255,255,.12); color: #fff; }

    /* Deploy row */
    .deploy-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 1.25rem 1.5rem; }
    .deploy-text { flex: 1; min-width: 180px; }
    .deploy-text h3 { font-size: .9rem; font-weight: 700; margin-bottom: .25rem; }
    .deploy-text p { font-size: .78rem; color: rgba(255,255,255,.45); line-height: 1.4; }
    .deploy-status { font-size: .72rem; color: rgba(255,255,255,.4); height: .9rem; }

    /* CMS cards */
    .section-label { font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.3); margin-bottom: .75rem; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: .75rem; margin-bottom: 1.5rem; }
    .card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.2rem; text-decoration: none; color: inherit; display: block; transition: all .15s; }
    .card:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.15); transform: translateY(-1px); }
    .card-icon { font-size: 1.3rem; margin-bottom: .6rem; }
    .card-title { font-size: .88rem; font-weight: 700; margin-bottom: .3rem; }
    .card-desc { font-size: .73rem; color: rgba(255,255,255,.4); line-height: 1.45; }

    /* Guide */
    .guide { background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.06); border-radius: 12px; padding: 1.25rem 1.5rem; }
    .guide h3 { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.3); margin-bottom: 1rem; }
    .steps { display: flex; flex-direction: column; gap: .65rem; }
    .step { display: flex; gap: .7rem; }
    .num { width: 20px; height: 20px; background: rgba(201,168,76,.15); color: #c9a84c; font-size: .66rem; font-weight: 800; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: .15rem; }
    .step p { font-size: .8rem; color: rgba(255,255,255,.5); line-height: 1.5; }
    .step p strong { color: rgba(255,255,255,.85); font-weight: 600; }

    #deploy-ok { display: none; }
  </style>
</head>
<body>

{!isAuthed ? (
  <div class="login">
    <div class="brand">Kancelaria ABW</div>
    <div class="brand-sub">Panel administracyjny</div>
    {error && <div class="error">❌ Nieprawidłowe hasło. Spróbuj ponownie.</div>}
    <form method="POST">
      <input type="password" name="password" placeholder="Hasło administratora" autofocus />
      <button type="submit" class="btn-primary">Zaloguj się →</button>
    </form>
  </div>
) : (
  <div class="dash">

    <!-- HEADER -->
    <div class="top-bar">
      <div class="brand-sm">Kancelaria ABW <span>Panel administracyjny</span></div>
      <a href="#" class="logout" id="logoutLink">Wyloguj</a>
    </div>

    <!-- TRYB PODGLĄDU: stan aktywny lub nieaktywny -->
    {isPreview ? (
      <div class="status-box preview">
        <div class="status-header">
          <div class="pulse gold"></div>
          <div class="status-title">Tryb podglądu szkiców jest WŁĄCZONY</div>
        </div>
        <div class="status-desc">
          Możesz teraz przeglądać swoją stronę i widzieć <strong style="color:rgba(255,255,255,.75)">wpisy bloga oznaczone jako "Szkic"</strong> — te których jeszcze nie opublikowałeś. Inni odwiedzający ich nie widzą.
        </div>
        <div style="margin-top:.75rem; font-size:.78rem; color:rgba(255,255,255,.45);">Zajrzyj na stronę i sprawdź jak wyglądają Twoje zmiany przed publikacją:</div>
        <div class="see-links">
          <a href="/blog" target="_blank" class="see-link">📝 Blog (lista artykułów)</a>
          <a href="/uslugi" target="_blank" class="see-link">⚖️ Usługi</a>
          <a href="/" target="_blank" class="see-link">🏠 Strona główna</a>
        </div>
        <div class="status-actions">
          <a href="/api/exit-preview" class="btn btn-ghost">✕ Wyłącz podgląd szkiców</a>
        </div>
      </div>
    ) : (
      <div class="status-box normal">
        <div class="status-header">
          <div class="pulse gray"></div>
          <div class="status-title gray">Tryb podglądu szkiców jest WYŁĄCZONY</div>
        </div>
        <div class="status-desc">
          Widzisz stronę tak jak zwykły odwiedzający — bez wpisów "Szkic". Włącz podgląd jeśli chcesz sprawdzić jak wygląda treść którą właśnie edytujesz, zanim ją opublikujesz.
        </div>
        <div class="status-actions">
          <a href="/api/preview?secret=abw-admin-preview" class="btn btn-outline-gold">👁 Włącz podgląd szkiców</a>
        </div>
      </div>
    )}

    <!-- DEPLOY -->
    <div class="deploy-row">
      <div class="deploy-text">
        <h3>🚀 Opublikuj zmiany na stronie</h3>
        <p>Kiedy zapiszesz zmiany w edytorze i jesteś gotowy — kliknij, żeby strona się przebudowała. Zajmuje to ~30 sekund.</p>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.4rem;">
        <button id="deployBtn" class="btn btn-gold" style="font-size:.85rem;padding:.65rem 1.4rem;">Opublikuj teraz</button>
        <div class="deploy-status" id="deployStatus"></div>
      </div>
    </div>

    <!-- EDYTOR CMS -->
    <div class="section-label">Edytuj treść strony</div>
    <div class="cards">
      <a href="/keystatic" class="card">
        <div class="card-icon">✏️</div>
        <div class="card-title">Wszystkie sekcje</div>
        <div class="card-desc">Pełny panel edytora Keystatic ze wszystkimi zakładkami.</div>
      </a>
      <a href="/keystatic/collection/blog" class="card">
        <div class="card-icon">📝</div>
        <div class="card-title">Blog</div>
        <div class="card-desc">Dodaj nowy artykuł lub edytuj istniejące wpisy.</div>
      </a>
      <a href="/keystatic/collection/services" class="card">
        <div class="card-icon">⚖️</div>
        <div class="card-title">Usługi prawne</div>
        <div class="card-desc">Opisy, FAQ i treść podstron usług kancelarii.</div>
      </a>
      <a href="/keystatic/singleton/contact" class="card">
        <div class="card-icon">📞</div>
        <div class="card-title">Dane kontaktowe</div>
        <div class="card-desc">Telefon, e-mail i adres widoczne na całej stronie.</div>
      </a>
      <a href="/keystatic/singleton/pricing" class="card">
        <div class="card-icon">💰</div>
        <div class="card-title">Cennik</div>
        <div class="card-desc">Tabela opłat za poszczególne usługi.</div>
      </a>
      <a href="/keystatic/singleton/homepage" class="card">
        <div class="card-icon">🏠</div>
        <div class="card-title">Strona główna</div>
        <div class="card-desc">Nagłówkowy tekst Hero i sekcja Q&A na dole.</div>
      </a>
    </div>

    <!-- INSTRUKCJA -->
    <div class="guide">
      <h3>📖 Jak wprowadzać zmiany — krok po kroku</h3>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <p>Kliknij jedną z kart powyżej (np. <strong>Blog</strong>) → wybierz wpis → zmień tekst → kliknij <strong>Zapisz</strong>.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <p><em>(Opcjonalnie)</em> Jeśli chcesz sprawdzić jak wygląda zmiana zanim ją opublikujesz: <strong>Włącz podgląd szkiców</strong> (powyżej) → otwórz zakładkę z blogiem → sprawdź wygląd.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <p>Gdy jesteś gotowy, kliknij <strong>Opublikuj teraz</strong>. Poczekaj ~30 sekund — zmiana pojawi się na żywej stronie.</p>
        </div>
        <div class="step">
          <div class="num">💡</div>
          <p><strong>Szkic</strong> = wpis który sam tylko widzisz (przez podgląd). Zwykli odwiedzający go nie zobaczą dopóki nie odznaczysz "Szkic" i nie klikniesz <strong>Opublikuj</strong>.</p>
        </div>
      </div>
    </div>

  </div>
)}

<script>
  document.getElementById('logoutLink')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.cookie = 'admin_auth=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
    window.location.href = '/admin';
  });

  const btn = document.getElementById('deployBtn') as HTMLButtonElement | null;
  const status = document.getElementById('deployStatus');
  btn?.addEventListener('click', async () => {
    if (btn) btn.disabled = true;
    btn.textContent = '⏳ Trwa...';
    if (status) status.textContent = 'Łączenie z serwerem...';
    try {
      const res = await fetch('/api/build', { method: 'POST' });
      if (res.ok) {
        btn.textContent = '✅ Gotowe!';
        if (status) status.textContent = 'Zmiany pojawią się za ~30 sekund.';
        setTimeout(() => {
          if (btn) btn.disabled = false;
          btn.textContent = 'Opublikuj teraz';
          if (status) status.textContent = '';
        }, 10000);
      } else {
        throw new Error();
      }
    } catch {
      btn.textContent = '❌ Błąd — spróbuj ponownie';
      if (btn) btn.disabled = false;
      if (status) status.textContent = 'Sprawdź czy serwer jest uruchomiony.';
    }
  });
</script>

</body>
</html>
