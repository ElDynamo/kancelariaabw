---
import { getEntry } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Button from '@components/ui/Button.astro';

const aboutEntry = await getEntry('singletons', 'about');
const data = aboutEntry?.data;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Anna Jarczyńska",
  "givenName": "Anna",
  "familyName": "Jarczyńska",
  "jobTitle": "Radca Prawny",
  "url": "https://kancelariaabw.pl/o-mnie",
  "identifier": "WR-3019",
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "name": "Wpis do listy radców prawnych",
    "credentialCategory": "Licencja zawodowa",
    "recognizedBy": {
      "@type": "Organization",
      "name": "Okręgowa Izba Radców Prawnych we Wrocławiu",
      "url": "https://oirp.wroclaw.pl"
    }
  },
  "memberOf": {
    "@type": "Organization",
    "name": "Kancelaria Prawna ABW",
    "url": "https://kancelariaabw.pl"
  },
  "alumniOf": "Okręgowa Izba Radców Prawnych we Wrocławiu",
  "knowsAbout": [
    "Prawo rodzinne", "Prawo cywilne", "Prawo karne",
    "Upadłość konsumencka", "Odszkodowania komunikacyjne",
    "Prawo nieruchomości", "Obsługa prawna firm",
    "Prawo pracy", "Ochrona danych osobowych"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "ul. Wiśniowa 3",
    "addressLocality": "Bielany Wrocławskie",
    "postalCode": "55-040",
    "addressCountry": "PL"
  },
  "telephone": "+48609366160",
  "email": "a.jarczynska@kancelariaabw.pl",
  "sameAs": [
    "https://oirp.wroclaw.pl/lista-radcow-prawnych",
    "https://lexspace.pl/prawnicy/8991305181-kancelaria-prawna-abw-radca-prawny-anna-jarczynska"
  ]
};
---

<Layout
  title="O mnie — Anna Jarczyńska, Radca Prawny Wrocław"
  description="Anna Jarczyńska — Radca Prawny z wpisem WR-3019. Doświadczona prawniczka specjalizująca się w prawie rodzinnym, cywilnym i karnym we Wrocławiu."
>
  <Fragment slot="head">
    <StructuredData schema={personSchema} />
  </Fragment>

  <!-- Hero sekcja -->
  <section class="section bg-off-white" aria-labelledby="about-heading">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="space-y-6 reveal">
        <div class="flex items-center gap-2">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">O mnie</span>
        </div>
        <h1 id="about-heading" class="heading-xl">{data?.hero?.title || "Anna Jarczyńska"}<br/><span class="text-gold">{data?.hero?.subtitle || "Radca Prawny"}</span></h1>
        
        {/* Obsługa Rich-text (Złamane paragrafy z Markdoc w Keystatic) */}
        {(data?.aboutParagraphs ? data.aboutParagraphs.split('\n\n') : []).filter(p => p.trim() !== '').map((p: string) => (
          <p class="text-body" set:html={p.replace(/\n/g, '<br/>')}></p>
        ))}
        
        <Button href="/kontakt" variant="primary">Umów spotkanie</Button>
      </div>
      <!-- Zdjęcie + Dane zawodowe -->
      <div class="space-y-6 reveal delay-200">
        <!-- Zdjęcie biurowe -->
        <div class="relative">
          <div class="aspect-square rounded-3xl overflow-hidden border border-border shadow-lg">
            <img
              src="/photos/mamachomika1.jpg"
              alt="Anna Jarczyńska — Radca Prawny w kancelarii we Wrocławiu"
              class="w-full h-full object-cover object-center"
              loading="eager"
              fetchpriority="high"
              width="500"
              height="500"
            />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-white border border-border rounded-2xl px-5 py-3 shadow-md">
            <p class="font-sans text-xs text-text-muted uppercase tracking-wide">Radca Prawny</p>
            <p class="font-serif text-navy text-base font-medium">WR-3019</p>
          </div>
        </div>
        <!-- Dane zawodowe -->
        <div class="bg-white rounded-3xl p-8 border border-border mt-8 reveal delay-300">
          <h2 class="font-sans text-xs uppercase tracking-widest text-gold mb-6">Dane zawodowe</h2>
          <dl class="space-y-4">
            {[
              { term: 'Tytuł zawodowy', def: 'Radca Prawny' },
              { term: 'Numer wpisu', def: 'WR-3019' },
              { term: 'Izba', def: 'OIRP Wrocław' },
              { term: 'Praktyka od', def: '2015 roku' },
              { term: 'Specjalizacje', def: 'Prawo rodzinne, cywilne, karne' },
              { term: 'Lokalizacje', def: 'Wrocław · Bielany Wrocławskie' },
            ].map(item => (
              <div class="grid grid-cols-2 gap-4 pb-4 border-b border-border last:border-0 last:pb-0">
                <dt class="font-sans text-sm text-text-muted">{item.term}</dt>
                <dd class="font-sans text-sm text-navy font-medium">{item.def}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div class="bg-off-white rounded-3xl p-8 border border-border reveal delay-400">
          <p class="font-serif text-navy text-lg italic leading-relaxed">
            „{data?.quote?.text}"
          </p>
          <p class="font-sans text-text-muted text-sm mt-4">— {data?.quote?.author}</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
