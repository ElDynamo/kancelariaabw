---
import Layout from '@components/layout/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('legal', 'dataprocessing');
if (!entry) throw new Error("Missing dataProcessing content in Keystatic.");
const { Content } = await entry.render();
---

<Layout
  title={`${entry.data.title} — Kancelaria Prawna ABW`}
  description={`Klauzula informacyjna RODO — ${entry.data.title}. Kancelaria Prawna ABW.`}
>
  <article class="section bg-white">
    <div class="container-site max-w-3xl">
      <div class="flex items-center gap-2 mb-4 reveal">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Dokumenty prawne</span>
      </div>
      <h1 class="heading-xl mb-2 reveal delay-100">{entry.data.title}</h1>
      <p class="font-sans text-sm text-text-muted mb-12 reveal delay-200">
        {entry.data.lastUpdated}
      </p>

      <div class="space-y-6 font-sans text-text [&_h2]:font-serif [&_h2]:text-navy [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 prose-p:text-body prose-ul:list-disc prose-ul:pl-6 prose-ul:space-y-2 prose-ul:text-body prose-a:text-gold hover:prose-a:underline reveal delay-300">
        <Content />
      </div>

      <div class="mt-10 p-6 bg-navy rounded-2xl text-center reveal delay-400">
        <p class="font-sans text-white opacity-80 text-sm mb-4">Masz pytania związane z przetwarzaniem danych?</p>
        <a href="mailto:a.jarczynska@kancelariaabw.pl" class="font-sans text-gold text-sm hover:underline">
          a.jarczynska@kancelariaabw.pl
        </a>
      </div>
    </div>
  </article>
</Layout>
