---
import { getEntry, render } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const serviceEntry = await getEntry('uslugi', 'upadlosc-konsumencka-wroclaw');
const data = serviceEntry?.data;
const renderResult = serviceEntry ? await render(serviceEntry) : null;
const Content = renderResult ? renderResult.Content : null;

const serviceSchema = {
  "@context": "https://schema.org", "@type": "LegalService",
  "name": "Upadłość konsumencka Wrocław — Kancelaria Prawna ABW",
  "url": "https://kancelariaabw.pl/uslugi/upadlosc-konsumencka-wroclaw",
  "telephone": "+48609366160",
  "priceRange": "$$",
  "description": data?.seoDescription || "Kompleksowa pomoc prawna przy upadłości konsumenckiej we Wrocławiu",
  "areaServed": ["Wrocław", "Bielany Wrocławskie", "Dolny Śląsk"],
  "provider": { "@type": "Person", "name": "Anna Jarczyńska", "jobTitle": "Radca Prawny" }
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": (data?.faq || []).map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer } }))
};
const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": data?.heroTitle || "Upadłość konsumencka", "item": "https://kancelariaabw.pl/uslugi/upadlosc-konsumencka-wroclaw" },
  ]
};
---

<Layout
  title={data?.title || "Upadłość Konsumencka Wrocław 2025"}
  description={data?.seoDescription || ""}
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={faqSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <section class="section bg-navy text-white overflow-hidden">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 font-sans text-sm text-white opacity-50">
            <li><a href="/" class="hover:text-white">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/uslugi" class="hover:text-white">Usługi</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-white opacity-80">{data?.heroTitle}</li>
          </ol>
        </nav>
        <div class="flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Prawo upadłościowe</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-5xl text-white mb-6 leading-tight">
          {data?.heroTitle}<br /><span class="text-gold">{data?.heroSubtitle}</span>
        </h1>
        <p class="font-sans text-white opacity-80 text-lg max-w-xl mb-8 leading-relaxed">
          {data?.heroDescription}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
            Bezpłatna wstępna ocena
          </a>
          <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
            609 366 160
          </a>
        </div>
      </div>
      <div class="relative reveal delay-200 hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative border border-white/10">
          <img src="/photos/hero_upadlosc_1772972068920.png" alt="Upadłość konsumencka prawnik" class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-gold/30 rounded-full -z-10"></div>
        <div class="absolute -top-6 -right-6 w-24 h-24 border border-gold/30 rounded-full -z-10"></div>
      </div>
    </div>
  </section>

  <!-- KROKI -->
  <section class="section bg-off-white">
    <div class="container-site max-w-5xl">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Jak działamy</span>
      </div>
      <h2 class="font-serif text-3xl text-navy mb-10">Proces upadłości krok po kroku</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {(data?.steps || []).map((k, idx) => (
          <div class="bg-white rounded-2xl p-6 border border-border">
            <p class="font-serif text-4xl text-gold opacity-30 font-bold mb-3">{String(idx + 1).padStart(2, '0')}</p>
            <h3 class="font-serif text-lg text-navy mb-2">{k.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{k.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TREŚĆ -->
  <section class="section bg-white">
    <div class="container-site max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <article class="lg:col-span-2 prose prose-navy max-w-none">
          {Content && <Content />}
        </article>

        <!-- SIDEBAR -->
        <aside class="space-y-6">
          <div class="bg-navy rounded-2xl p-6 sticky top-6">
            <p class="font-sans text-xs text-white opacity-60 uppercase tracking-widest mb-3">Bezpłatna ocena</p>
            <p class="font-serif text-xl text-white mb-4">Sprawdź czy kwalifikujesz się do upadłości</p>
            <ul class="space-y-2 mb-6">
              {["Analiza Twojego zadłużenia", "Ocena szans na oddłużenie", "Omówienie kolejnych kroków"].map(i => (
                <li class="flex items-center gap-2 font-sans text-sm text-white opacity-80">
                  <span class="text-gold">✓</span> {i}
                </li>
              ))}
            </ul>
            <a href="/kontakt" class="block text-center py-3 px-5 rounded-lg font-semibold text-sm"
              style="background:#c9a84c; color:#0f2540;">Umów rozmowę →</a>
            <a href="tel:+48609366160" class="block text-center mt-3 font-sans text-sm text-white opacity-70 hover:text-white">
              📞 609 366 160
            </a>
          </div>

          <div class="bg-off-white rounded-2xl p-6 border border-border">
            <h3 class="font-serif text-base text-navy mb-3">Powiązane narzędzia</h3>
            <ul class="space-y-2 font-sans text-sm">
              <li><a href="/narzedzia/oplaty-sadowe" class="text-navy hover:text-gold transition-colors">→ Kalkulator opłat sądowych</a></li>
              <li><a href="/narzedzia/przedawnienie-roszczen" class="text-navy hover:text-gold transition-colors">→ Kalkulator przedawnienia</a></li>
              <li><a href="/narzedzia/koszty-rozwodu" class="text-navy hover:text-gold transition-colors">→ Kalkulator kosztów sprawy</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-off-white">
    <div class="container-site max-w-3xl">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">FAQ</span>
      </div>
      <h2 class="font-serif text-3xl text-navy mb-8">Najczęstsze pytania o upadłość konsumencką</h2>
      <div class="space-y-4">
        {(data?.faq || []).map(f => (
          <details class="bg-white rounded-xl border border-border p-5 group">
            <summary class="font-sans font-semibold text-navy cursor-pointer list-none flex justify-between items-center">
              {f.question}
              <span class="text-gold text-lg ml-4">+</span>
            </summary>
            <p class="font-sans text-text-muted text-sm mt-3 leading-relaxed">{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA KOŃCOWE -->
  <section class="section bg-navy">
    <div class="container-site max-w-3xl text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Zacznij od bezpłatnej rozmowy</h2>
      <p class="font-sans text-white opacity-70 mb-8 max-w-lg mx-auto">
        Powiemy Ci wprost — czy Twoja sytuacja kwalifikuje się do upadłości i co Cię czeka.
        Bez zobowiązań, bez ukrytych kosztów.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
          Skontaktuj się z kancelarią
        </a>
        <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
          Zadzwoń: 609 366 160
        </a>
      </div>
    </div>
  </section>
</Layout>
