---
import { getCollection, render } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import ServiceHero from '@components/ui/ServiceHero.astro';
import CTASection from '@components/ui/CTASection.astro';
import FAQAccordion from '@components/ui/FAQAccordion.astro';
import StructuredData from '@components/seo/StructuredData.astro';

export async function getStaticPaths() {
  const services = await getCollection('uslugi');
  const customLayouts = [
    'prawo-karne', 
    'prawo-nieruchomosci-wroclaw', 
    'upadlosc-konsumencka-wroclaw', 
    'obsluga-prawna-firm-wroclaw', 
    'odszkodowania-komunikacyjne-wroclaw',
    'prawo-gospodarcze',
  ];
  const genericServices = services.filter(s => !customLayouts.includes(s.slug));

  return genericServices.map(entry => ({
    params: { slug: entry.slug },
    props: { service: entry },
  }));
}

const { service } = Astro.props;
const data = service.data;
const { Content } = await render(service);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": data.title,
  "provider": {
    "@type": "LegalService",
    "name": "Kancelaria Prawna ABW",
    "telephone": "+48609366160"
  },
  "serviceType": "Legal Services",
  "areaServed": "Wrocław",
  "description": data.seo?.description
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": data.hero?.title, "item": `https://kancelariaabw.pl/uslugi/${service.id}` },
  ]
};
---

<Layout
  title={data.title}
  description={data.seo?.description || ''}
  image={data.seo?.ogImage || data.hero?.image || undefined}
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <ServiceHero
    title={data.hero?.title}
    subtitle={data.hero?.subtitle}
    description={data.hero?.description}
    image={data.hero?.image}
    imageAlt={data.hero?.title}
  />

  <section class="section bg-white pt-10">
    <div class="container-site max-w-4xl">
      {data.features && data.features.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
          {data.features.map(item => (
            <div class="bg-off-white rounded-xl p-5 border border-border border-l-4 border-l-navy/20 hover:border-l-navy transition-colors">
              <h2 class="font-serif text-lg text-navy mb-2">{item.title}</h2>
              <p class="font-sans text-sm text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-navy">
         <Content />
      </div>
    </div>
  </section>

  <FAQAccordion items={data.faq || []} title="Najczęstsze pytania" />

  <CTASection />
</Layout>
