---
import { getCollection, render } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import CTASection from '@components/ui/CTASection.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Button from '@components/ui/Button.astro';

export async function getStaticPaths() {
  const services = await getCollection('uslugi');
  const customLayouts = [
    'prawo-karne', 
    'prawo-nieruchomosci-wroclaw', 
    'upadlosc-konsumencka-wroclaw', 
    'obsluga-prawna-firm-wroclaw', 
    'odszkodowania-komunikacyjne-wroclaw'
  ];
  const genericServices = services.filter(s => !customLayouts.includes(s.slug));

  return genericServices.map(entry => ({
    params: { slug: entry.slug },
    props: { service: entry },
  }));
}

const { service } = Astro.props;
const data = service.data;
const { Content } = await render(service);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": data.title,
  "provider": {
    "@type": "LegalService",
    "name": "Kancelaria Prawna ABW",
    "telephone": "+48609366160"
  },
  "serviceType": "Legal Services",
  "areaServed": "Wrocław",
  "description": data.seo?.description
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": data.hero?.title, "item": `https://kancelariaabw.pl/uslugi/${service.id}` },
  ]
};
---

<Layout
  title={data.title}
  description={data.seo?.description || ''}
  image={data.seo?.ogImage || data.hero?.image || undefined}
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <!-- HERO -->
  <section class="section bg-navy text-white overflow-hidden">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 font-sans text-sm text-white opacity-50">
            <li><a href="/" class="hover:text-white">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/uslugi" class="hover:text-white">Usługi</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-white opacity-80">{data.hero?.title}</li>
          </ol>
        </nav>
        <div class="flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Usługi prawne</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-5xl text-white mb-6 leading-tight">
          {data.hero?.title}<br /><span class="text-gold">{data.hero?.subtitle}</span>
        </h1>
        <p class="font-sans text-white opacity-80 text-lg max-w-xl mb-8 leading-relaxed">
          {data.hero?.description}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
            Umów konsultację
          </a>
          <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
            609 366 160
          </a>
        </div>
      </div>
      <div class="relative reveal delay-200 hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative border border-white/10">
          <img src={data.hero?.image} alt={data.hero?.title} class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-gold/30 rounded-full -z-10"></div>
        <div class="absolute -top-6 -right-6 w-24 h-24 border border-gold/30 rounded-full -z-10"></div>
      </div>
    </div>
  </section>

  <section class="section bg-white pt-10">
    <div class="container-site max-w-4xl">
      {data.features && data.features.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
          {data.features.map(item => (
            <div class="bg-off-white rounded-xl p-5 border border-border border-l-4 border-l-navy/20 hover:border-l-navy transition-colors">
              <h2 class="font-serif text-lg text-navy mb-2">{item.title}</h2>
              <p class="font-sans text-sm text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-navy">
         <Content />
      </div>
    </div>
  </section>

  {data.faq && data.faq.length > 0 && (
    <section class="section bg-off-white">
      <div class="container-site max-w-3xl">
        <div class="flex items-center gap-2 mb-3">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">FAQ</span>
        </div>
        <h2 class="font-serif text-3xl text-navy mb-8">Najczęstsze pytania</h2>
        <div class="space-y-4">
          {data.faq.map(f => (
            <details class="bg-white rounded-xl border border-border p-5 group">
              <summary class="font-sans font-semibold text-navy cursor-pointer list-none flex justify-between items-center">
                {f.question}
                <span class="text-gold text-lg ml-4">+</span>
              </summary>
              <p class="font-sans text-text-muted text-sm mt-3 leading-relaxed">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection />
</Layout>
