---
import Layout from '@components/layout/Layout.astro';
import CTASection from '@components/ui/CTASection.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Prawo karne Wrocław",
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW", "telephone": "+48609366160" },
  "serviceType": "Legal Services",
  "areaServed": "Wrocław"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": "Prawo karne", "item": "https://kancelariaabw.pl/uslugi/prawo-karne" },
  ]
};

const scopeOfWork = [
  { title: 'Obrona w postępowaniu karnym', desc: 'Reprezentacja podejrzanego i oskarżonego na etapie postępowania przygotowawczego i przed sądem we wszystkich instancjach.' },
  { title: 'Reprezentacja pokrzywdzonych', desc: 'Aktywna ochrona interesów ofiar przestępstw — występowanie w charakterze oskarżyciela posiłkowego oraz dochodzenie roszczeń w drodze powództwa cywilnego.' },
  { title: 'Sprawy karnoskarbowe', desc: 'Skuteczna obrona w zawiłych postępowaniach dotyczących przestępstw i wykroczeń skarbowych.' },
  { title: 'Wykroczenia', desc: 'Profesjonalna reprezentacja w sprawach o wykroczenia przed sądem oraz organami administracyjnymi.' },
  { title: 'Alternatywne rozwiązania', desc: 'Starania o warunkowe umorzenie postępowania, dobrowolne poddanie się karze lub zawieszenie wykonania kary.' },
  { title: 'Etap wykonawczy', desc: 'Sporządzanie wniosków o odroczenie kary, przerwę w wykonaniu kary oraz warunkowe przedterminowe zwolnienie.' },
];
---

<Layout
  title="Prawo karne Wrocław — Obrona w sprawach karnych"
  description="Kancelaria Prawna ABW — obrona w sprawach karnych i karnoskarbowych we Wrocławiu. Reprezentacja podejrzanych i pokrzywdzonych. Tel: 609 366 160."
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <!-- HERO -->
  <section class="section bg-navy text-white overflow-hidden">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 font-sans text-sm text-white opacity-50">
            <li><a href="/" class="hover:text-white">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/uslugi" class="hover:text-white">Usługi</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-white opacity-80">Prawo karne</li>
          </ol>
        </nav>
        <div class="flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Obrona i reprezentacja</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-5xl text-white mb-6 leading-tight">
          Prawo karne<br /><span class="text-gold">Wrocław i okolice</span>
        </h1>
        <p class="font-sans text-white opacity-80 text-lg max-w-xl mb-8 leading-relaxed">
          W obliczu zarzutów karnych kluczowe jest natychmiastowe działanie i chłodna analiza. Zapewniamy profesjonalną pomoc na każdym etapie — od pierwszego przesłuchania po prawomocny wyrok.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
            Pilna pomoc
          </a>
          <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
            609 366 160
          </a>
        </div>
      </div>
      <div class="relative reveal delay-200 hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative border border-white/10">
          <img src="/photos/hero_prawo_karne_1772972023278.png" alt="Obrona karna adwokat radca" class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-gold/30 rounded-full -z-10"></div>
        <div class="absolute -top-6 -right-6 w-24 h-24 border border-gold/30 rounded-full -z-10"></div>
      </div>
    </div>
  </section>

  <!-- CONTENT GRID -->
  <section class="py-20 lg:py-32 bg-white">
    <div class="container-site max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        
        <!-- SIDEBAR -->
        <div class="lg:col-span-4 reveal">
          <div class="sticky top-32">
            <h2 class="font-serif text-2xl text-navy mb-6">Dla kogo?</h2>
            <ul class="flex flex-col gap-4 font-sans text-sm text-text-muted border-b border-border/50 pb-8 mb-8">
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">―</span>
                <span>Osoby podejrzane o popełnienie przestępstwa lub wykroczenia.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">―</span>
                <span>Oskarżeni w procesach karnych i karnoskarbowych.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">―</span>
                <span>Pokrzywdzeni potrzebujący reprezentacji swoich praw przed sądem.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold mt-1">―</span>
                <span>Skazani ubiegający się o przerwę, odroczenie wkonania kary lub SDE.</span>
              </li>
            </ul>

            <div class="bg-off-white p-8 border border-border/50">
               <h3 class="font-serif text-xl text-navy mb-4">Potrzebujesz pilnej pomocy?</h3>
               <p class="font-sans text-sm text-text-muted mb-6">W sprawach nagłych (zatrzymanie, przeszukanie) prosimy o natychmiastowy kontakt telefoniczny.</p>
               <a href="tel:+48609366160" class="inline-flex font-sans text-sm text-navy uppercase tracking-widest border-b border-navy pb-1 hover:text-gold hover:border-gold transition-colors">
                  Zadzwoń: 609 366 160
               </a>
            </div>
          </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="lg:col-span-8 reveal delay-200">
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-12">Zakres ochrony prawnej</h2>
          
          <div class="flex flex-col gap-12">
            {scopeOfWork.map((item, index) => (
              <div class="relative pl-8 md:pl-12 border-l border-border/50 group hover:border-gold/50 transition-colors duration-500">
                <span class="absolute left-0 top-0 -translate-x-1/2 text-gold font-serif text-sm px-1 leading-none bg-white">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <h3 class="font-serif text-2xl text-navy mb-3">{item.title}</h3>
                <p class="font-sans text-base text-text-muted leading-relaxed max-w-xl">{item.desc}</p>
              </div>
            ))}
          </div>

          <div class="mt-20 pt-12 border-t border-border/50">
             <h2 class="font-serif text-3xl text-navy mb-6">Jak pracujemy?</h2>
             <div class="prose prose-lg max-w-none text-text-muted">
               <p>
                 Każda sprawa karna wymaga indywidualnej, dopracowanej strategii obrończej. Pracę zawsze rozpoczynamy od <strong>szczegółowej analizy akt sprawy</strong> oraz rzetelnej, szczerej rozmowy z Klientem.
               </p>
               <p>
                 Nie obiecujemy niemożliwego, ale gwarantujemy pełne zaangażowanie, poszukiwanie najkorzystniejszych rozwiązań prawnych (takich jak warunkowe umorzenie postępowania) oraz bezkompromisową walkę o Twoje prawa przed organami ścigania i sądem.
               </p>
             </div>
          </div>

        </div>
        
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
