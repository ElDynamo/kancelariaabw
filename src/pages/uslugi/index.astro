---
import Layout from '@components/layout/Layout.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import Button from '@components/ui/Button.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const services = [
  {
    icon: <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18M3 9l9-6 9 6M6 12l-3 6h6l-3-6zm12 0l-3 6h6l-3-6z"/></svg>,
    title: 'Prawo rodzinne',

    title: 'Prawo rodzinne',
    description: 'Rozwód, alimenty, podział majątku, władza rodzicielska, kontakty z dziećmi.',
    href: '/uslugi/prawo-rodzinne',
  },
  {
    icon: <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>,
    title: 'Prawo cywilne',

    title: 'Prawo cywilne',
    description: 'Umowy, roszczenia, prawo spadkowe, windykacja należności.',
    href: '/uslugi/prawo-cywilne',
  },
  {
    icon: <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>,
    title: 'Prawo karne',

    title: 'Prawo karne',
    description: 'Obrona w sprawach karnych i karnoskarbowych, reprezentacja pokrzywdzonych.',
    href: '/uslugi/prawo-karne',
  },
];

const pillarServices = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
    title: 'Upadłość konsumencka — Wrocław',
    description: 'Zadłużony? Pomożemy ogłosić upadłość i zacząć od nowa. Zatrzymaj komornika.',
    href: '/uslugi/upadlosc-konsumencka-wroclaw',
    badge: 'Najwyższy priorytet',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Odszkodowania komunikacyjne',
    description: 'Wypadek drogowy? Ubezpieczyciel zaniżył wypłatę? Uzyskamy pełne odszkodowanie.',
    href: '/uslugi/odszkodowania-komunikacyjne-wroclaw',
    badge: null,
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Prawo nieruchomości',
    description: 'Eksmisje, najem, bezumowne korzystanie z lokalu, zakup i sprzedaż nieruchomości.',
    href: '/uslugi/prawo-nieruchomosci-wroclaw',
    badge: null,
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Obsługa prawna firm',
    description: 'Umowy B2B, windykacja, ochrona przed nieuczciwą konkurencją, RODO.',
    href: '/uslugi/obsluga-prawna-firm-wroclaw',
    badge: null,
  },
];

const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
  ]
};
---

<Layout
  title="Usługi prawne Wrocław — Radca Prawny Anna Jarczyńska | Kancelaria ABW"
  description="Kancelaria Prawna ABW oferuje pomoc prawną we Wrocławiu i Bielanach Wrocławskich: upadłość, odszkodowania, prawo rodzinne, nieruchomości, obsługa firm. Tel. 609 366 160."
>
  <Fragment slot="head">
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <!-- HERO -->
  <section class="section bg-navy text-white">
    <div class="container-site max-w-4xl text-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Co oferujemy</span>
        <span class="h-px w-8 bg-gold"></span>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl text-white mb-5">Usługi prawne Wrocław</h1>
      <p class="font-sans text-white/70 text-lg max-w-2xl mx-auto mb-8">
        Radca Prawny Anna Jarczyńska świadczy kompleksową pomoc prawną dla osób fizycznych i przedsiębiorców
        na terenie Wrocławia, Bielan Wrocławskich i Dolnego Śląska.
      </p>
    </div>
  </section>

  <!-- PILLAR PAGES — główne specjalizacje SEO -->
  <section class="py-16 lg:py-20 bg-off-white">
    <div class="container-site">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Specjalizacje</span>
      </div>
      <h2 class="font-serif text-3xl text-navy mb-2">Główne obszary praktyki</h2>
      <p class="font-sans text-text-muted mb-10">Szczegółowe strony z pełnym opisem procedur, FAQ i podstawami prawnymi.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {pillarServices.map(s => (
          <a href={s.href} class="group bg-white rounded-2xl p-7 border border-border hover:border-navy hover:shadow-lg transition-all block">
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 rounded-xl bg-navy/5 flex items-center justify-center text-navy group-hover:bg-navy group-hover:text-white transition-all">
                <Fragment set:html={s.icon} />
              </div>
              {s.badge && (
                <span class="font-sans text-xs px-2 py-1 rounded-full text-navy/60 border border-border">{s.badge}</span>
              )}
            </div>
            <h3 class="font-serif text-xl text-navy mb-2 group-hover:text-gold transition-colors">{s.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed mb-4">{s.description}</p>
            <span class="font-sans text-xs text-navy/50 group-hover:text-gold transition-colors">Dowiedz się więcej →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- OGÓLNE OBSZARY PRAWA -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="container-site">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Ogólne obszary</span>
      </div>
      <h2 class="font-serif text-3xl text-navy mb-10">Pozostałe obszary prawa</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={s.href} class="group bg-off-white rounded-2xl p-6 border border-border hover:border-navy transition-all block">
            <div class="w-12 h-12 rounded-xl bg-navy/5 flex items-center justify-center text-navy mb-4 group-hover:bg-navy group-hover:text-white transition-colors"><Fragment set:html={s.icon} /></div>
            <h3 class="font-serif text-lg text-navy mb-2 group-hover:text-gold transition-colors">{s.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{s.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-navy">
    <div class="container-site max-w-3xl text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Nie wiesz, czy możemy Ci pomóc?</h2>
      <p class="font-sans text-white/70 mb-8 max-w-xl mx-auto">
        Opisz swoją sytuację — bezpłatnie ocenimy zakres możliwej pomocy prawnej.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
          Skontaktuj się
        </a>
        <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
          609 366 160
        </a>
      </div>
    </div>
  </section>
</Layout>

