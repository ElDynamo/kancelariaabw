---
import { getEntry, render } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import ServiceHero from '@components/ui/ServiceHero.astro';
import FAQAccordion from '@components/ui/FAQAccordion.astro';
import Button from '@components/ui/Button.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const serviceEntry = await getEntry('uslugi', 'obsluga-prawna-firm-wroclaw');
const data = serviceEntry?.data;
const renderResult = serviceEntry ? await render(serviceEntry) : null;
const Content = renderResult ? renderResult.Content : null;

const serviceSchema = {
  "@context": "https://schema.org", "@type": "LegalService",
  "name": "Obsługa prawna firm Wrocław — Kancelaria ABW",
  "url": "https://kancelariaabw.pl/uslugi/obsluga-prawna-firm-wroclaw",
  "telephone": "+48609366160",
  "description": data?.seoDescription || "Obsługa prawna przedsiębiorstw we Wrocławiu",
  "areaServed": ["Wrocław", "Dolny Śląsk"],
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": (data?.faq || []).map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer } }))
};
const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": data?.heroTitle || "Obsługa prawna firm", "item": "https://kancelariaabw.pl/uslugi/obsluga-prawna-firm-wroclaw" },
  ]
};
---

<Layout
  title={data?.title || "Obsługa Prawna Firm Wrocław"}
  description={data?.seoDescription || ""}
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={faqSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <ServiceHero
    title={data?.heroTitle}
    subtitle={data?.heroSubtitle}
    description={data?.heroDescription}
    label="Prawo gospodarcze"
    ctaText="Zapytaj o abonament"
    image="/photos/hero_obsluga_firm_1772972083263.png"
    imageAlt="Obsługa prawna firm biznes"
  />

  <section class="section bg-off-white">
    <div class="container-site max-w-5xl">
      <h2 class="font-serif text-3xl text-navy mb-10">Zakres obsługi prawnej firm</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {(data?.features || []).map(u => (
          <div class="bg-white rounded-2xl p-6 border border-border hover:border-navy transition-colors">
            <div class="text-3xl mb-3">{u.icon}</div>
            <h3 class="font-serif text-lg text-navy mb-2">{u.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-site max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <article class="lg:col-span-2 prose prose-navy max-w-none">
          {Content && <Content />}
        </article>
        <aside class="space-y-6">
          <div class="bg-navy rounded-2xl p-6 sticky top-6">
            <p class="font-sans text-xs text-white opacity-60 uppercase tracking-widest mb-3">Dla firm</p>
            <p class="font-serif text-xl text-white mb-4">Stała obsługa lub jednorazowe zlecenie</p>
            <ul class="space-y-2 mb-6">
              {["Abonament miesięczny", "Wynagrodzenie od sukcesu (windykacja)", "Szybka reakcja — 24h"].map(i => (
                <li class="flex items-center gap-2 font-sans text-sm text-white opacity-80">
                  <span class="text-gold">✓</span> {i}
                </li>
              ))}
            </ul>
            <Button href="/kontakt" variant="gold" class="w-full justify-center">Skontaktuj się →</Button>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <FAQAccordion items={data?.faq || []} title="Pytania o obsługę prawną firm" />
</Layout>
