---
import Layout from '@components/layout/Layout.astro';
import CTASection from '@components/ui/CTASection.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Button from '@components/ui/Button.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Prawo rodzinne Wrocław",
  "provider": {
    "@type": "LegalService",
    "name": "Kancelaria Prawna ABW",
    "telephone": "+48609366160"
  },
  "serviceType": "Legal Services",
  "areaServed": "Wrocław",
  "description": "Pomoc prawna w sprawach rodzinnych: rozwód, alimenty, podział majątku, władza rodzicielska"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": "Prawo rodzinne", "item": "https://kancelariaabw.pl/uslugi/prawo-rodzinne" },
  ]
};
---

<Layout
  title="Prawo rodzinne Wrocław — Rozwód, Alimenty, Podział majątku"
  description="Radca Prawny Anna Jarczyńska — pomoc prawna w sprawach rodzinnych we Wrocławiu. Rozwód, alimenty, podział majątku, władza rodzicielska. Zadzwoń: 609 366 160."
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

    <!-- HERO -->
  <section class="section bg-navy text-white overflow-hidden">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 font-sans text-sm text-white opacity-50">
            <li><a href="/" class="hover:text-white">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/uslugi" class="hover:text-white">Usługi</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-white opacity-80">Prawo rodzinne</li>
          </ol>
        </nav>
        <div class="flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Usługi prawne</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-5xl text-white mb-6 leading-tight">
          Prawo rodzinne<br /><span class="text-gold">Wrocław i okolice</span>
        </h1>
        <p class="font-sans text-white opacity-80 text-lg max-w-xl mb-8 leading-relaxed">
          Sprawy rodzinne są jednymi z najbardziej delikatnych. Radca Prawny Anna Jarczyńska oferuje profesjonalne wsparcie, pełną dyskrecję i zrozumienie w tych wymagających momentach.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
            Umów konsultację
          </a>
          <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
            609 366 160
          </a>
        </div>
      </div>
      <div class="relative reveal delay-200 hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative border border-white/10">
          <img src="/photos/hero_prawo_rodzinne_sq.png" alt="Prawo rodzinne rozwód prawnik" class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-gold/30 rounded-full -z-10"></div>
        <div class="absolute -top-6 -right-6 w-24 h-24 border border-gold/30 rounded-full -z-10"></div>
      </div>
    </div>
  </section>

  <section class="section bg-white pt-10">
    <div class="container-site max-w-4xl">
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        {[
          { title: 'Rozwód', desc: 'Prowadzenie spraw o rozwód — zarówno bez orzekania o winie, jak i z orzekaniem. Reprezentacja przed sądem okręgowym.' },
          { title: 'Alimenty', desc: 'Ustalenie, podwyższenie lub obniżenie alimentów. Egzekucja alimentów z pomocą komornika.' },
          { title: 'Podział majątku', desc: 'Podział majątku wspólnego małżonków — sądowy i umowny. Doradztwo w zakresie podziału nieruchomości i innych składników.' },
          { title: 'Władza rodzicielska', desc: 'Ustalenie miejsca zamieszkania dziecka, ograniczenie lub pozbawienie władzy rodzicielskiej.' },
          { title: 'Kontakty z dziećmi', desc: 'Ustalenie i egzekwowanie kontaktów rodzica z dzieckiem po rozstaniu.' },
          { title: 'Separacja', desc: 'Orzeczenie separacji jako alternatywa dla rozwodu przy czasowych trudnościach małżeńskich.' },
        ].map(item => (
          <div class="bg-off-white rounded-xl p-5 border border-border border-l-4 border-l-navy/20 hover:border-l-navy transition-colors">
            <h2 class="font-serif text-lg text-navy mb-2">{item.title}</h2>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
