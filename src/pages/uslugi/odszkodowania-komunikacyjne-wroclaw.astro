---
import { getEntry, render } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const serviceEntry = await getEntry('uslugi', 'odszkodowania-komunikacyjne-wroclaw');
const data = serviceEntry?.data;
const renderResult = serviceEntry ? await render(serviceEntry) : null;
const Content = renderResult ? renderResult.Content : null;

const serviceSchema = {
  "@context": "https://schema.org", "@type": "LegalService",
  "name": "Odszkodowania komunikacyjne Wrocław — Kancelaria ABW",
  "url": "https://kancelariaabw.pl/uslugi/odszkodowania-komunikacyjne-wroclaw",
  "telephone": "+48609366160", "priceRange": "$$",
  "description": data?.seoDescription || "Dochodzenie odszkodowań komunikacyjnych we Wrocławiu",
  "areaServed": ["Wrocław", "Bielany Wrocławskie", "Dolny Śląsk"],
  "provider": { "@type": "Person", "name": "Anna Jarczyńska", "jobTitle": "Radca Prawny" }
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": (data?.faq || []).map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer } }))
};
const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": data?.heroTitle || "Odszkodowania komunikacyjne", "item": "https://kancelariaabw.pl/uslugi/odszkodowania-komunikacyjne-wroclaw" },
  ]
};
---

<Layout
  title={data?.title || "Odszkodowania Komunikacyjne Wrocław"}
  description={data?.seoDescription || ""}
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={faqSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <!-- HERO -->
  <section class="section bg-navy text-white overflow-hidden">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 font-sans text-sm text-white opacity-50">
            <li><a href="/" class="hover:text-white">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/uslugi" class="hover:text-white">Usługi</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-white opacity-80">{data?.heroTitle}</li>
          </ol>
        </nav>
        <div class="flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Prawo cywilne</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-5xl text-white mb-6 leading-tight">
          {data?.heroTitle}<br /><span class="text-gold">{data?.heroSubtitle}</span>
        </h1>
        <p class="font-sans text-white opacity-80 text-lg max-w-xl mb-8 leading-relaxed">
          {data?.heroDescription}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
            Bezpłatna analiza
          </a>
          <a href="tel:+48609366160" class="font-sans text-white border border-white/30 rounded-lg px-6 py-3.5 hover:bg-white/10 transition-colors">
            609 366 160
          </a>
        </div>
      </div>
      <div class="relative reveal delay-200 hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative border border-white/10">
          <img src="/photos/hero_odszkodowania_1772972097118.png" alt="Odszkodowania auta wypadek prawnik" class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-gold/30 rounded-full -z-10"></div>
        <div class="absolute -top-6 -right-6 w-24 h-24 border border-gold/30 rounded-full -z-10"></div>
      </div>
    </div>
  </section>

  <!-- ZAKRES -->
  <section class="section bg-off-white">
    <div class="container-site max-w-5xl">
      <div class="flex items-center gap-2 mb-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Zakres pomocy</span>
      </div>
      <h2 class="font-serif text-3xl text-navy mb-10">Co możemy dla Ciebie zrobić?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {(data?.features || []).map(z => (
          <div class="bg-white rounded-2xl p-6 border border-border hover:border-navy transition-colors">
            <div class="text-3xl mb-3">{z.icon}</div>
            <h3 class="font-serif text-lg text-navy mb-2">{z.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{z.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTYKUŁ -->
  <section class="section bg-white">
    <div class="container-site max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <article class="lg:col-span-2 prose prose-navy max-w-none">
          {Content && <Content />}
        </article>

        <aside class="space-y-6">
          <div class="bg-navy rounded-2xl p-6 sticky top-6">
            <p class="font-sans text-xs text-white opacity-60 uppercase tracking-widest mb-3">Oceń swoją sprawę</p>
            <p class="font-serif text-xl text-white mb-4">Sprawdź czy ubezpieczyciel musiał wypłacić więcej</p>
            <ul class="space-y-2 mb-6">
              {["Bezpłatna analiza decyzji ubezpieczyciela", "Ocena szans na wyższe odszkodowanie", "Bez zaliczek — wynagrodzenie od sukcesu"].map(i => (
                <li class="flex items-center gap-2 font-sans text-sm text-white opacity-80">
                  <span class="text-gold">✓</span> {i}
                </li>
              ))}
            </ul>
            <a href="/kontakt" class="block text-center py-3 px-5 rounded-lg font-semibold text-sm"
              style="background:#c9a84c; color:#0f2540;">Umów rozmowę →</a>
          </div>
          <div class="bg-off-white rounded-2xl p-6 border border-border">
            <h3 class="font-serif text-base text-navy mb-3">Powiązane artykuły</h3>
            <ul class="space-y-2 font-sans text-sm">
              <li><a href="/narzedzia/oplaty-sadowe" class="text-navy hover:text-gold">→ Kalkulator opłat sądowych</a></li>
              <li><a href="/uslugi/prawo-cywilne" class="text-navy hover:text-gold">→ Prawo cywilne ogólne</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-off-white">
    <div class="container-site max-w-3xl">
      <h2 class="font-serif text-3xl text-navy mb-8">Pytania o odszkodowania komunikacyjne</h2>
      <div class="space-y-4">
        {(data?.faq || []).map(f => (
          <details class="bg-white rounded-xl border border-border p-5">
            <summary class="font-sans font-semibold text-navy cursor-pointer list-none flex justify-between items-center">
              {f.question}<span class="text-gold text-lg ml-4">+</span>
            </summary>
            <p class="font-sans text-text-muted text-sm mt-3 leading-relaxed">{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-navy">
    <div class="container-site max-w-3xl text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Ubezpieczyciel zaniżył wypłatę?</h2>
      <p class="font-sans text-white opacity-70 mb-8 max-w-lg mx-auto">
        Bezpłatnie przeanalizujemy decyzję ubezpieczyciela i powiemy Ci czy masz podstawy do odwołania.
      </p>
      <a href="/kontakt" class="btn-primary" style="background:#c9a84c; color:#0f2540; font-size:1rem; padding: 0.875rem 2rem;">
        Umów bezpłatną konsultację
      </a>
    </div>
  </section>
</Layout>
