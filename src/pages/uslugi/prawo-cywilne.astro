---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Prawo cywilne Wrocław",
  "provider": { "@type": "LegalService", "name": "Kancelaria Prawna ABW", "telephone": "+48609366160" },
  "serviceType": "Legal Services",
  "areaServed": "Wrocław"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": "https://kancelariaabw.pl/uslugi" },
    { "@type": "ListItem", "position": 3, "name": "Prawo cywilne", "item": "https://kancelariaabw.pl/uslugi/prawo-cywilne" },
  ]
};
---

<Layout
  title="Prawo cywilne Wrocław — Umowy, Odszkodowania, Nieruchomości"
  description="Kancelaria Prawna ABW — pomoc w sprawach cywilnych: umowy, odszkodowania, nieruchomości, prawo spadkowe. Radca Prawny Wrocław. Tel: 609 366 160."
>
  <Fragment slot="head">
    <StructuredData schema={serviceSchema} />
    <StructuredData schema={breadcrumb} />
  </Fragment>

  <section class="section bg-white">
    <div class="container-site max-w-4xl">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-sans text-sm text-text-muted">
          <li><a href="/" class="hover:text-navy">Strona główna</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/uslugi" class="hover:text-navy">Usługi</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-navy">Prawo cywilne</li>
        </ol>
      </nav>

      <div class="flex items-center gap-2 mb-4">
        <span class="h-px w-8 bg-gold"></span>
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Usługi</span>
      </div>
      <h1 class="heading-xl mb-6">Prawo cywilne<br/><span class="text-gold">Wrocław</span></h1>
      <p class="text-body text-lg mb-10">
        Prawo cywilne reguluje stosunki między osobami fizycznymi i prawnymi. Kancelaria oferuje kompleksową pomoc prawną od sporządzania umów po reprezentację w sporach majątkowych.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        {[
          { title: 'Umowy', desc: 'Przygotowanie i opiniowanie umów cywilnoprawnych: sprzedaży, najmu, dzierżawy, zlecenia, o dzieło i innych.' },
          { title: 'Odszkodowania', desc: 'Dochodzenie roszczeń odszkodowawczych: wypadki komunikacyjne, błędy medyczne, szkody majątkowe.' },
          { title: 'Nieruchomości', desc: 'Transakcje nieruchomościami, umowy deweloperskie, zniesienie współwłasności, zasiedzenie.' },
          { title: 'Prawo spadkowe', desc: 'Stwierdzenie nabycia spadku, dział spadku, zachowek, odrzucenie spadku.' },
          { title: 'Windykacja', desc: 'Dochodzenie należności pieniężnych — postępowanie sądowe i egzekucyjne.' },
          { title: 'Spory sądowe', desc: 'Reprezentacja w postępowaniach cywilnych przed sądami wszystkich instancji.' },
        ].map(item => (
          <div class="bg-off-white rounded-xl p-5 border border-border">
            <h2 class="font-serif text-lg text-navy mb-2">{item.title}</h2>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="bg-navy rounded-3xl p-8 text-center">
        <h2 class="font-serif text-2xl text-white mb-3">Masz sprawę cywilną?</h2>
        <p class="font-sans text-white/70 mb-6">Skontaktuj się — omówimy Twoją sytuację i zaproponujemy najlepsze rozwiązanie.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/kontakt" class="btn-primary bg-gold text-navy hover:bg-gold-light">Umów konsultację</a>
          <a href="tel:+48609366160" class="btn-outline border-white text-white hover:bg-white hover:text-navy">609 366 160</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
