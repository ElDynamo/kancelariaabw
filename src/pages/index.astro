---
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import Button from '@components/ui/Button.astro';
import CTASection from '@components/ui/CTASection.astro';

import { getEntry } from 'astro:content';

const homepageEntry = await getEntry('singletons', 'homepage');

// Pobranie zaktualizowanego schematu (Nested)
const homepageData = homepageEntry?.data || {};
const heroContent = homepageData.hero || {
  title: 'Radca Prawny',
  subtitle: 'we Wrocławiu',
  description: 'Anna Jarczyńska — doświadczona radca prawna z wpisem WR-3019. Skuteczna pomoc prawna w sprawach rodzinnych, cywilnych i karnych.'
};
const aboutContent = homepageData.about || {
  description1: 'Radca prawny z wpisem nr WR-3019...',
  description2: 'Prowadzę kancelarię...'
};

const faqItems = homepageData.faq || [];

const legalServiceSchema = {
  "@context": "https://schema.org",
  "@type": ["LegalService", "LocalBusiness"],
  "name": "Kancelaria Prawna ABW",
  "description": "Radca Prawny Anna Jarczyńska — profesjonalna pomoc prawna we Wrocławiu. Prawo rodzinne, cywilne i karne.",
  "url": "https://kancelariaabw.pl",
  "telephone": "+48609366160",
  "email": "a.jarczynska@kancelariaabw.pl",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Wrocław",
    "addressRegion": "dolnośląskie",
    "addressCountry": "PL"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 51.1079,
    "longitude": 17.0385
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": "Wrocław",
  "memberOf": {
    "@type": "Organization",
    "name": "Okręgowa Izba Radców Prawnych we Wrocławiu"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Radca Prawny Wrocław — Kancelaria Prawna ABW"
  description="Kancelaria Prawna ABW — Radca Prawny Anna Jarczyńska. Profesjonalna pomoc prawna we Wrocławiu: prawo rodzinne, cywilne, karne. Zadzwoń: 609 366 160."
>
  <Fragment slot="head">
    <StructuredData schema={legalServiceSchema} />
    <StructuredData schema={faqSchema} />
  </Fragment>

  <!-- HERO -->
  <section class="relative bg-white overflow-hidden" aria-labelledby="hero-heading">
    <div class="container-site section grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Tekst -->
      <div class="flex flex-col gap-6 lg:gap-8 reveal">
        <div class="inline-flex items-center gap-2 self-start">
          <span class="h-px w-8 bg-gold"></span>
          <span class="font-sans text-xs uppercase tracking-widest text-gold">Kancelaria Prawna</span>
        </div>
        <h1 id="hero-heading" class="heading-xl">
          {heroContent.title}<br/>
          <span class="text-gold">{heroContent.subtitle}</span>
        </h1>
        <p class="text-body text-lg max-w-lg">
          {heroContent.description}
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="/kontakt" variant="primary" size="lg">Umów konsultację</Button>
          <Button href="/uslugi" variant="outline" size="lg">Nasze usługi</Button>
        </div>
        <div class="flex gap-8 pt-4 border-t border-border">
          <div>
            <p class="font-serif text-3xl text-navy">10+</p>
            <p class="font-sans text-xs text-text-muted uppercase tracking-wide">lat doświadczenia</p>
          </div>
          <div>
            <p class="font-serif text-3xl text-navy">100%</p>
            <p class="font-sans text-xs text-text-muted uppercase tracking-wide">zaangażowania</p>
          </div>
        </div>
      </div>
      <!-- Zdjęcie — desktop 4/5 portrait, mobile poziomy banner -->
      <div class="relative w-full reveal delay-200">
        <!-- Mobile: poziomy baner kadrowany na górę (twarz) -->
        <div class="lg:hidden w-full overflow-hidden rounded-2xl border border-border"
             style="height: 280px;">
          <img
            src="/photos/mamachomika2.jpg"
            alt="Anna Jarczyńska — Radca Prawny Wrocław"
            class="w-full h-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
            width="600"
            height="280"
          />
        </div>
        <!-- Desktop: pionowy portrait -->
        <div class="hidden lg:block relative">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden border border-border">
            <img
              src="/photos/mamachomika2.jpg"
              alt="Anna Jarczyńska — Radca Prawny Wrocław"
              class="w-full h-full object-cover object-top"
              loading="eager"
              fetchpriority="high"
              width="500"
              height="625"
            />
          </div>
          <!-- Dekoracje -->
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-gold/10 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-navy/5 rounded-xl -z-10"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- USŁUGI -->
  <section class="section bg-off-white" aria-labelledby="services-heading">
    <div class="container-site">
      <div class="text-center mb-12 reveal">
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Czym się zajmujemy</span>
        <h2 id="services-heading" class="heading-lg mt-2">W czym pomagamy?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 reveal delay-200">
        <ServiceCard
          title="Prawo rodzinne"
          description="Wsparcie w trudnych chwilach. Prowadzimy sprawy o rozwód, alimenty, podział majątku oraz władzę rodzicielską, dbając przede wszystkim o Twój spokój."
          href="/uslugi/prawo-rodzinne"
        >
          <!-- Ikona: waga sprawiedliwości -->
          <svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a3a5c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v18M3 9l9-6 9 6M6 12l-3 6h6l-3-6zm12 0l-3 6h6l-3-6z"/>
          </svg>
        </ServiceCard>
        <ServiceCard
          title="Prawo cywilne"
          description="Rozwiązywanie codziennych problemów. Pomagamy w sprawach o zapłatę, odszkodowania, a także doradzamy przy spornych umowach i sprawach spadkowych."
          href="/uslugi/prawo-cywilne"
        >
          <!-- Ikona: dokument/kontrakt -->
          <svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a3a5c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </ServiceCard>
        <ServiceCard
          title="Prawo karne"
          description="Reprezentujemy oskarżonych i pokrzywdzonych. Działamy w postępowaniu przygotowawczym i karnym."
          href="/uslugi/prawo-karne"
        >
          <!-- Ikona: tarcza -->
          <svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a3a5c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </ServiceCard>
        <ServiceCard
          title="Prawo gospodarcze"
          description="Obsługujemy spółki handlowe oraz jednoosobowe działalności gospodarcze. Pomożemy w rejestracji, zmianach oraz umowach."
          href="/uslugi/obsluga-prawna-firm-wroclaw"
        >
          <!-- Ikona: walizka/firma -->
          <svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a3a5c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="16"/>
            <line x1="10" y1="14" x2="14" y2="14"/>
          </svg>
        </ServiceCard>
      </div>

      <div class="text-center mt-10">
        <Button href="/uslugi" variant="outline">Zobacz wszystkie usługi</Button>
      </div>
    </div>
  </section>

  <section class="section bg-white" aria-labelledby="about-heading">
    <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-6 reveal">
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Poznaj mnie</span>
        <h2 id="about-heading" class="heading-lg">Anna Jarczyńska<br/><span class="text-gold">Radca Prawny</span></h2>
        <p class="text-body">
          {aboutContent.description1}
        </p>
        <p class="text-body">
          {aboutContent.description2}
        </p>
        <Button href="/o-mnie" variant="ghost">Przeczytaj więcej →</Button>
      </div>
      <div class="relative reveal delay-200">
        <div class="aspect-square lg:aspect-[4/5] rounded-3xl overflow-hidden border border-border shadow-lg">
          <img
            src="/photos/mamachomika1.jpg"
            alt="Anna Jarczyńska — Radca Prawny w kancelarii we Wrocławiu"
            class="w-full h-full object-cover object-center"
            loading="lazy"
            width="500"
            height="625"
          />
        </div>
        <!-- Odznaka wpisu -->
        <div class="absolute -bottom-4 -right-4 bg-white border border-border rounded-2xl px-5 py-3 shadow-md">
          <p class="font-sans text-xs text-text-muted uppercase tracking-wide">Radca Prawny</p>
          <p class="font-serif text-navy text-base font-medium">WR-3019</p>
        </div>
      </div>

    </div>
  </section>

  <section class="section bg-off-white" aria-labelledby="faq-heading">
    <div class="container-site">
      <div class="text-center mb-14 reveal">
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Często zadawane pytania</span>
        <h2 id="faq-heading" class="heading-lg mt-2">Masz pytania?</h2>
        <p class="text-body max-w-xl mx-auto mt-3">Odpowiadamy na najczęstsze wątpliwości dotyczące współpracy z kancelarią.</p>
      </div>

      <!-- 2-kolumnowy grid Q&A -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 reveal delay-100">
        {faqItems.map((item) => (
          <article class="border-l-2 border-gold pl-5 space-y-2">
            <h3 class="font-serif text-xl text-navy leading-snug">{item.question}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{item.answer}</p>
          </article>
        ))}
      </div>

      <!-- CTA pod Q&A — wyraźny card -->
      <div class="mt-14 border border-border rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-5 bg-white reveal delay-200">
        <div>
          <p class="font-sans text-xs uppercase tracking-widest text-gold mb-1">Masz inne pytanie?</p>
          <p class="font-serif text-lg text-navy">Nie znalazłeś odpowiedzi na swoje pytanie?</p>
          <p class="font-sans text-sm text-text-muted mt-1">Skontaktuj się bezpośrednio — odpiszemy w ciągu 24h.</p>
        </div>
        <Button href="/kontakt" variant="primary">Napisz do nas</Button>
      </div>

    </div>
  </section>

  <CTASection
    variant="dark"
    title="Potrzebujesz pomocy prawnej?"
    description="Skontaktuj się z nami — wspólnie przeanalizujemy Twoją sytuację i zaproponujemy najlepsze rozwiązanie."
    buttonText="Umów konsultację"
  />
</Layout>
