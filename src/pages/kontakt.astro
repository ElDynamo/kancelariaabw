---
import { getEntry } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import ContactForm from '@components/forms/ContactForm.vue';
import Map from '@components/forms/Map.vue';

const contactEntry = await getEntry('singletons', 'contact');
const data = contactEntry?.data;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LegalService", "LocalBusiness"],
  "name": "Kancelaria Prawna ABW",
  "telephone": data?.phone || "+48609366160",
  "email": data?.email || "a.jarczynska@kancelariaabw.pl",
  "address": { "@type": "PostalAddress", "addressLocality": "Wrocław", "addressCountry": "PL" },
  "geo": { "@type": "GeoCoordinates", "latitude": 51.1079, "longitude": 17.0385 },
  "openingHours": "Mo-Fr 09:00-17:00"
};
---

<Layout
  title="Kontakt — Kancelaria Prawna ABW Wrocław"
  description="Skontaktuj się z Kancelarią Prawną ABW we Wrocławiu. Tel: 609 366 160. Formularz kontaktowy, mapa dojazdu, dane kancelarii."
>
  <Fragment slot="head">
    <StructuredData schema={localBusinessSchema} />
  </Fragment>

  <section class="section bg-white">
    <div class="container-site">
      <div class="text-center mb-14 reveal">
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Jesteśmy do dyspozycji</span>
        <h1 class="heading-xl mt-2">Kontakt</h1>
      </div>

      <div class="flex flex-col-reverse lg:grid lg:grid-cols-2 gap-12 lg:items-start">
        <!-- Dane kontaktowe + Mapa -->
        <div class="space-y-6 reveal delay-100">
          <div class="bg-off-white rounded-3xl p-8 border border-border">
            <h2 class="font-sans text-xs uppercase tracking-widest text-gold mb-6">Dane kancelarii</h2>
            <dl class="space-y-5">
              <div>
                <dt class="font-sans text-xs text-text-muted uppercase tracking-wide mb-1">Telefon</dt>
                <dd><a href={`tel:${data?.phone?.replace(/\s+/g, '')}`} class="font-serif text-xl text-navy hover:text-gold transition-colors">{data?.phone}</a></dd>
              </div>
              <div>
                <dt class="font-sans text-xs text-text-muted uppercase tracking-wide mb-1">Email</dt>
                <dd><a href={`mailto:${data?.email}`} class="font-sans text-base text-navy hover:text-gold transition-colors">{data?.email}</a></dd>
              </div>
              <div>
                <dt class="font-sans text-xs text-text-muted uppercase tracking-wide mb-1">Godziny pracy</dt>
                <dd class="font-sans text-sm text-navy">{data?.hours}</dd>
              </div>
              <div>
                <dt class="font-sans text-xs text-text-muted uppercase tracking-wide mb-1">Lokalizacje</dt>
                <dd class="font-sans text-sm text-navy">{data?.locations}</dd>
              </div>
            </dl>
          </div>

          <!-- Mapa Leaflet — Vue Island, ładuje się gdy wejdzie w viewport -->
          <div class="rounded-3xl overflow-hidden border border-border" style="height: 400px;">
            <Map client:visible />
          </div>
        </div>

        <!-- Formularz kontaktowy — Vue Island -->
        <div class="bg-off-white rounded-3xl p-8 border border-border reveal delay-200">
          <h2 class="font-serif text-2xl text-navy mb-6">Napisz do nas</h2>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</Layout>
