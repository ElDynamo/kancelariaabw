---
import { getCollection, getEntry } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Button from '@components/ui/Button.astro';
import AuthorWidget from '@components/blog/AuthorWidget.astro';

// Aby zadziałał tryb Preview (cookies), ten plik nie może być generowany statycznie u wszystkich.
// Ale podstrony powinny być szybkie. Astro domyślnie przy `output: 'server'` uruchamia wszystko jako SSR.
export const prerender = false;

// Pobieranie wpisu bez getStaticPaths
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404'); // Zabezpieczenie typu
const post = await getEntry('blog', slug);

if (!post) {
  return new Response("Nie znaleziono artykułu", { status: 404 });
}

// Sprawdzenie trybu Preview - wyłuskujemy cookie
const hasPreviewCookie = Astro.request.headers.get('cookie')?.includes('preview=true');

// Odmów dostępu dla zwykłych klientów jeśli wpis to szkic (draft)
if (post.data.draft && !hasPreviewCookie) {
  return new Response("Ten artykuł nie jest jeszcze opublikowany.", { status: 404 });
}

// Mapowanie Autora (Relacja CMS)
const authorEntry = await getEntry('authors', post.data.author.id || post.data.author);
const authorData = authorEntry?.data;

// Powiązana usługa (Cross-Sell)
const relatedServiceEntry = post.data.relatedService ? await getEntry('uslugi', post.data.relatedService) : null;

const { Content } = await post.render();

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.publishDate.toISOString(),
  "dateModified": (post.data.lastModified ?? post.data.publishDate).toISOString?.() ?? post.data.publishDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": authorData?.name || "Kancelaria ABW",
    "jobTitle": authorData?.role || "Prawnik",
    "url": authorData?.linkedin || "https://kancelariaabw.pl/o-mnie"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Kancelaria Prawna ABW",
    "url": "https://kancelariaabw.pl"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://kancelariaabw.pl/blog/${post.slug}`
  },
  "keywords": post.data.tags.join(', ')
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://kancelariaabw.pl" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://kancelariaabw.pl/blog" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://kancelariaabw.pl/blog/${post.slug}` },
  ]
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.ogImage || undefined}
  type="article"
>
  <Fragment slot="head">
    <StructuredData schema={blogPostingSchema} />
    <StructuredData schema={breadcrumb} />
    <meta property="article:published_time" content={post.data.publishDate.toISOString()} />
    <meta property="article:author" content={post.data.author} />
    <meta property="article:section" content={post.data.category} />
    {post.data.tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <article class="section bg-white">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8 flex items-center justify-between">
          <ol class="flex items-center gap-2 font-sans text-sm text-text-muted flex-wrap">
            <li><a href="/" class="hover:text-navy">Strona główna</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/blog" class="hover:text-navy">Blog</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page" class="text-navy line-clamp-1">{post.data.title}</li>
          </ol>
          {post.data.draft && (
            <span class="bg-amber-100 text-amber-800 border border-amber-300 px-3 py-1 rounded text-xs font-bold shadow-sm whitespace-nowrap">
              ⚠️ TRYB PODGLĄDU (SZKIC)
            </span>
          )}
        </nav>

        <!-- Header -->
        <header class="mb-10">
          <span class="font-sans text-xs uppercase tracking-widest text-gold">{post.data.category}</span>
          <h1 class="heading-xl mt-3 mb-4">{post.data.title}</h1>
          <div class="flex items-center gap-4 text-text-muted font-sans text-sm">
            <span>Autor: <strong class="text-navy">{authorData?.name || post.data.author}</strong></span>
            <span aria-hidden="true">·</span>
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
          </div>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4" aria-label="Tagi">
              {post.data.tags.map(tag => (
                <span class="font-sans text-xs bg-off-white text-text-muted px-3 py-1 rounded-full border border-border">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- Author Widget (E-E-A-T) -->
        <AuthorWidget
          author={authorData}
          publishDate={post.data.publishDate}
          lastModified={(post.data as any).lastModified}
        />

        <!-- Content -->
        <div class="prose prose-lg max-w-none
          [&_h2]:font-serif [&_h2]:text-navy [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:font-serif [&_h3]:text-navy [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3
          [&_p]:font-sans [&_p]:text-text-muted [&_p]:leading-relaxed [&_p]:mb-4
          [&_ul]:space-y-2 [&_ul]:my-4
          [&_li]:font-sans [&_li]:text-text-muted [&_li]:text-base [&_li]:leading-relaxed
          [&_strong]:text-navy [&_strong]:font-semibold
          [&_a]:text-gold [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-navy
          [&_hr]:border-border [&_hr]:my-8">
          <Content />
        </div>

        {/* --- DYNAMICZNY CROSS-SELL (POWIĄZANA USŁUGA) --- */}
        {relatedServiceEntry && (
          <div class="mt-12 bg-gray-50 border border-gray-100 rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-center sm:items-start justify-between">
            <div class="flex-1 space-y-2">
              <span class="font-sans text-[10px] font-bold tracking-widest uppercase text-navy/50 bg-navy/5 px-2 py-1 rounded">Polecana usługa</span>
              <h3 class="font-serif text-xl sm:text-2xl text-navy leading-tight">{relatedServiceEntry.data.title}</h3>
              <p class="font-sans text-sm text-text-muted leading-relaxed">
                {relatedServiceEntry.data.hero?.description || relatedServiceEntry.data.seo?.description}
              </p>
            </div>
            <a href={`/uslugi/${relatedServiceEntry.slug}`} class="shrink-0 btn-primary whitespace-nowrap">
              Dowiedz się więcej
            </a>
          </div>
        )}

        <!-- CTA bottom — premium 2-kolumnowy panel -->
        <aside class="mt-12 rounded-3xl overflow-hidden" aria-label="Kontakt z kancelarią"
          style="background: linear-gradient(135deg, #0f2540 0%, #1a3a5c 100%);">
          <div class="p-8 lg:p-10 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <!-- Lewa: tekst + CTA -->
            <div class="space-y-4">
              <p class="font-sans text-xs uppercase tracking-widest text-gold">Potrzebujesz pomocy?</p>
              <h2 class="font-serif text-2xl lg:text-3xl text-white leading-tight">
                Ten artykuł to ogólna informacja.<br/>
                <span class="text-gold">Twoja sprawa jest wyjątkowa.</span>
              </h2>
              <p class="font-sans text-white/70 text-sm">
                Skontaktuj się z kancelarią — przeanalizujemy Twoją sytuację i przedstawimy dostępne opcje.
              </p>
              <div class="flex flex-wrap gap-3 pt-1">
                <a href="/kontakt"
                  class="inline-block px-5 py-2.5 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg"
                  style="background:#c9a84c; color:#0f2540;">
                  Umów konsultację
                </a>
                <a href="tel:+48609366160"
                  class="inline-block px-5 py-2.5 font-sans font-semibold text-sm uppercase tracking-wide rounded-lg border-2 border-white/60 text-white">
                  609 366 160
                </a>
              </div>
            </div>
            <!-- Prawa: dane kontaktowe -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
              <p class="font-sans text-xs uppercase tracking-widest text-gold mb-2">Dane kancelarii</p>
              {[
                { label: 'Telefon', value: '609 366 160', href: 'tel:+48609366160' },
                { label: 'Email', value: 'a.jarczynska@kancelariaabw.pl', href: 'mailto:a.jarczynska@kancelariaabw.pl' },
                { label: 'Lokalizacje', value: 'Wrocław · Bielany Wrocławskie', href: null },
                { label: 'Godziny', value: 'Pon.–Pt., 9:00–17:00', href: null },
              ].map(item => (
                <div>
                  <p class="font-sans text-xs text-white/40 uppercase tracking-wide">{item.label}</p>
                  {item.href
                    ? <a href={item.href} class="font-sans text-sm text-white hover:text-gold transition-colors">{item.value}</a>
                    : <p class="font-sans text-sm text-white">{item.value}</p>
                  }
                </div>
              ))}
            </div>
          </div>
        </aside>


        <div class="mt-8 flex justify-between items-center">
          <a href="/blog" class="font-sans text-sm text-text-muted hover:text-navy transition-colors">
            ← Wróć do bloga
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
