---
import { getEntry } from 'astro:content';
import Layout from '@components/layout/Layout.astro';
import Button from '@components/ui/Button.astro';

const pricingEntry = await getEntry('singletons', 'pricing');
const data = pricingEntry?.data;
---

<Layout
  title="Cennik usług prawnych — Kancelaria Prawna ABW Wrocław"
  description="Cennik Kancelarii Prawnej ABW we Wrocławiu. Przejrzyste stawki za porady prawne, prowadzenie spraw i zastępstwo procesowe. Zadzwoń: 609 366 160."
>
  <section class="section bg-white">
    <div class="container-site max-w-4xl">
      <div class="text-center mb-14 reveal">
        <span class="font-sans text-xs uppercase tracking-widest text-gold">Transparentność</span>
        <h1 class="heading-xl mt-2">Cennik</h1>
        <p class="text-body max-w-2xl mx-auto mt-4">
          {data?.hero?.description}
        </p>
      </div>

      <div class="space-y-3 mb-14 reveal delay-100">
        {(data?.pricingList || []).map(item => (
          <div class="flex flex-col sm:flex-row sm:items-center justify-between bg-off-white rounded-xl px-6 py-4 border border-border gap-2">
            <div>
              <p class="font-sans text-base text-navy">{item.service}</p>
              {item.note && <p class="font-sans text-xs text-text-muted mt-0.5">{item.note}</p>}
            </div>
            <p class="font-serif text-lg text-gold font-normal whitespace-nowrap">{item.price}</p>
          </div>
        ))}
      </div>

      <div class="bg-off-white rounded-3xl p-8 border border-border mb-8 reveal delay-200">
        <h2 class="font-serif text-xl text-navy mb-4">Ważne informacje</h2>
        <ul class="space-y-3 font-sans text-sm text-text-muted">
          {(data?.importantInfo || []).map(info => (
            <li class="flex gap-3"><span class="text-gold mt-0.5">●</span> {info}</li>
          ))}
        </ul>
      </div>

      <div class="text-center reveal delay-300">
        <Button href="/kontakt" variant="primary" size="lg">Zapytaj o wycenę swojej sprawy</Button>
      </div>
    </div>
  </section>
</Layout>
